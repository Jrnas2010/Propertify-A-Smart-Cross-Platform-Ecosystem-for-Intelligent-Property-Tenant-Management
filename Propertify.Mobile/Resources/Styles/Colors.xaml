<?xml version="1.0" encoding="UTF-8" ?>
<ResourceDictionary
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">

    <!-- ── Propertify Brand Colors ────────────────────────────────────── -->
    <Color x:Key="BrandPrimary">#1e3a5f</Color>
    <Color x:Key="BrandAccent">#3b82f6</Color>
    <Color x:Key="BrandGreen">#10b981</Color>
    <Color x:Key="BrandAmber">#f59e0b</Color>
    <Color x:Key="BrandRed">#ef4444</Color>
    <Color x:Key="BrandBg">#f8fafc</Color>
    <Color x:Key="BrandText">#0f172a</Color>
    <Color x:Key="BrandMuted">#64748b</Color>
    <Color x:Key="BrandBorder">#e2e8f0</Color>

    <!-- ── Override MAUI defaults to brand colors ─────────────────────── -->
    <Color x:Key="Primary">#1e3a5f</Color>
    <Color x:Key="PrimaryDark">#3b82f6</Color>
    <Color x:Key="PrimaryDarkText">#ffffff</Color>
    <Color x:Key="Secondary">#3b82f6</Color>
    <Color x:Key="SecondaryDarkText">#ffffff</Color>
    <Color x:Key="Tertiary">#10b981</Color>

    <Color x:Key="White">White</Color>
    <Color x:Key="Black">Black</Color>
    <Color x:Key="OffBlack">#0f172a</Color>

    <Color x:Key="Gray100">#f8fafc</Color>
    <Color x:Key="Gray200">#f1f5f9</Color>
    <Color x:Key="Gray300">#e2e8f0</Color>
    <Color x:Key="Gray400">#94a3b8</Color>
    <Color x:Key="Gray500">#64748b</Color>
    <Color x:Key="Gray600">#475569</Color>
    <Color x:Key="Gray900">#0f172a</Color>
    <Color x:Key="Gray950">#020617</Color>

    <SolidColorBrush x:Key="PrimaryBrush"   Color="{StaticResource Primary}"/>
    <SolidColorBrush x:Key="SecondaryBrush" Color="{StaticResource Secondary}"/>
    <SolidColorBrush x:Key="TertiaryBrush"  Color="{StaticResource Tertiary}"/>
    <SolidColorBrush x:Key="WhiteBrush"     Color="{StaticResource White}"/>
    <SolidColorBrush x:Key="BlackBrush"     Color="{StaticResource Black}"/>

    <SolidColorBrush x:Key="Gray100Brush" Color="{StaticResource Gray100}"/>
    <SolidColorBrush x:Key="Gray200Brush" Color="{StaticResource Gray200}"/>
    <SolidColorBrush x:Key="Gray300Brush" Color="{StaticResource Gray300}"/>
    <SolidColorBrush x:Key="Gray400Brush" Color="{StaticResource Gray400}"/>
    <SolidColorBrush x:Key="Gray500Brush" Color="{StaticResource Gray500}"/>
    <SolidColorBrush x:Key="Gray600Brush" Color="{StaticResource Gray600}"/>
    <SolidColorBrush x:Key="Gray900Brush" Color="{StaticResource Gray900}"/>
    <SolidColorBrush x:Key="Gray950Brush" Color="{StaticResource Gray950}"/>

</ResourceDictionary>
