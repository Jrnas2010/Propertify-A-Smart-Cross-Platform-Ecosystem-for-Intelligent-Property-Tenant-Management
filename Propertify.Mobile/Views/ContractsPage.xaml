<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Propertify.Mobile.Views.ContractsPage"
             Title="Contracts"
             BackgroundColor="#f8fafc">

    <Shell.TitleView>
        <Label Text="Contracts" FontSize="18" FontAttributes="Bold"
               TextColor="White" VerticalOptions="Center" Margin="4,0,0,0"/>
    </Shell.TitleView>

    <Grid RowDefinitions="Auto,*">

        <!-- Header -->
        <Border Grid.Row="0" BackgroundColor="#1e3a5f" Padding="20,36,20,20" StrokeThickness="0">
            <VerticalStackLayout Spacing="4">
                <Label Text="LEASE CONTRACTS" FontSize="10" FontAttributes="Bold"
                       TextColor="#93c5fd" CharacterSpacing="1.5"/>
                <Label Text="Your rental agreements" FontSize="20" FontAttributes="Bold" TextColor="White"/>
            </VerticalStackLayout>
        </Border>

        <!-- Content -->
        <RefreshView Grid.Row="1"
                     IsRefreshing="{Binding IsRefreshing}"
                     Command="{Binding RefreshCommand}">
            <CollectionView ItemsSource="{Binding Contracts}"
                            BackgroundColor="Transparent"
                            Margin="0,12">

                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <Border BackgroundColor="White" Margin="16,0,16,14"
                                Padding="20" StrokeThickness="0">
                            <Border.StrokeShape><RoundRectangle CornerRadius="20"/></Border.StrokeShape>
                            <Border.Shadow><Shadow Brush="Black" Offset="0,2" Radius="10" Opacity="0.07"/></Border.Shadow>
                            <VerticalStackLayout Spacing="14">

                                <!-- Header row -->
                                <Grid ColumnDefinitions="*,Auto">
                                    <VerticalStackLayout Grid.Column="0" Spacing="3">
                                        <Label Text="{Binding PropertyName}" FontSize="16"
                                               FontAttributes="Bold" TextColor="#0f172a"/>
                                        <Label Text="{Binding UnitNumber, StringFormat='Unit {0}'}"
                                               FontSize="13" TextColor="#3b82f6" FontAttributes="Bold"/>
                                    </VerticalStackLayout>
                                    <Border Grid.Column="1" Padding="12,6" StrokeThickness="0"
                                            BackgroundColor="{Binding Status, Converter={StaticResource StatusToColorConverter}}">
                                        <Border.StrokeShape><RoundRectangle CornerRadius="20"/></Border.StrokeShape>
                                        <Label Text="{Binding Status}" FontSize="11"
                                               FontAttributes="Bold" TextColor="White"/>
                                    </Border>
                                </Grid>

                                <!-- Divider -->
                                <BoxView HeightRequest="1" Color="#f1f5f9"/>

                                <!-- Dates -->
                                <Grid ColumnDefinitions="*,*">
                                    <VerticalStackLayout Grid.Column="0" Spacing="2">
                                        <Label Text="START DATE" FontSize="9" FontAttributes="Bold"
                                               TextColor="#94a3b8" CharacterSpacing="0.8"/>
                                        <Label Text="{Binding StartDate}" FontSize="13"
                                               FontAttributes="Bold" TextColor="#0f172a"/>
                                    </VerticalStackLayout>
                                    <VerticalStackLayout Grid.Column="1" Spacing="2">
                                        <Label Text="END DATE" FontSize="9" FontAttributes="Bold"
                                               TextColor="#94a3b8" CharacterSpacing="0.8"/>
                                        <Label Text="{Binding EndDate}" FontSize="13"
                                               FontAttributes="Bold" TextColor="#0f172a"/>
                                    </VerticalStackLayout>
                                </Grid>

                                <!-- Progress -->
                                <VerticalStackLayout Spacing="6">
                                    <Grid ColumnDefinitions="*,Auto">
                                        <Label Grid.Column="0" Text="Contract Duration"
                                               FontSize="11" TextColor="#64748b"/>
                                        <Label Grid.Column="1"
                                               Text="{Binding DaysRemaining, StringFormat='{0} days left'}"
                                               FontSize="11" FontAttributes="Bold" TextColor="#f59e0b"/>
                                    </Grid>
                                    <ProgressBar Progress="0.6" ProgressColor="#3b82f6"
                                                 BackgroundColor="#e2e8f0" HeightRequest="6"/>
                                </VerticalStackLayout>

                                <!-- Rent amounts -->
                                <Grid ColumnDefinitions="*,*">
                                    <VerticalStackLayout Grid.Column="0" Spacing="2">
                                        <Label Text="TOTAL VALUE" FontSize="9" FontAttributes="Bold"
                                               TextColor="#94a3b8" CharacterSpacing="0.8"/>
                                        <Label Text="{Binding RentAmount, StringFormat='{0:N3} OMR'}"
                                               FontSize="15" FontAttributes="Bold" TextColor="#1e3a5f"/>
                                    </VerticalStackLayout>
                                    <VerticalStackLayout Grid.Column="1" Spacing="2">
                                        <Label Text="MONTHLY" FontSize="9" FontAttributes="Bold"
                                               TextColor="#94a3b8" CharacterSpacing="0.8"/>
                                        <Label Text="{Binding MonthlyRent, StringFormat='{0:N3} OMR'}"
                                               FontSize="15" FontAttributes="Bold" TextColor="#3b82f6"/>
                                    </VerticalStackLayout>
                                </Grid>
                            </VerticalStackLayout>
                        </Border>
                    </DataTemplate>
                </CollectionView.ItemTemplate>

                <CollectionView.EmptyView>
                    <VerticalStackLayout HorizontalOptions="Center" VerticalOptions="Center"
                                         Spacing="12" Padding="40">
                        <Label Text="📄" FontSize="48" HorizontalOptions="Center"/>
                        <Label Text="No Contracts Found" FontSize="16" FontAttributes="Bold"
                               TextColor="#0f172a" HorizontalOptions="Center"/>
                        <Label Text="Your lease contracts will appear here once added by the property manager."
                               FontSize="13" TextColor="#94a3b8" HorizontalOptions="Center"
                               HorizontalTextAlignment="Center"/>
                    </VerticalStackLayout>
                </CollectionView.EmptyView>
            </CollectionView>
        </RefreshView>

        <!-- Loading -->
        <ActivityIndicator Grid.Row="1" IsRunning="{Binding IsBusy}"
                           IsVisible="{Binding IsBusy}"
                           Color="#3b82f6" VerticalOptions="Center" HorizontalOptions="Center"/>
    </Grid>
</ContentPage>
