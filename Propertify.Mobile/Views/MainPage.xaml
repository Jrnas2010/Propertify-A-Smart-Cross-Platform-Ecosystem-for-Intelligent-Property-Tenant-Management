<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Propertify.Mobile.Views.MainPage"
             BackgroundColor="#F8F9FA"
             Shell.NavBarIsVisible="False">

    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="20">
            <Label Text="Welcome, Hamad" FontSize="22" FontAttributes="Bold" TextColor="#2C3E50" />

            <Frame BackgroundColor="#2C3E50" CornerRadius="15" HasShadow="True">
                <VerticalStackLayout>
                    <Label Text="Rental for April" TextColor="White" Opacity="0.7" />
                    <Label Text="250.000 OMR" FontSize="32" TextColor="White" FontAttributes="Bold" />
                </VerticalStackLayout>
            </Frame>

            <Frame BackgroundColor="#FEF9E7" BorderColor="#F7DC6F">
                <Label Text="🔔 Alert: Water Tank Maintenance Tomorrow at 10 AM" TextColor="#9A7D0A" />
            </Frame>

            <Grid ColumnDefinitions="*,*" ColumnSpacing="15">
                <Button Grid.Column="0" Text="🔧 Maintenance" BackgroundColor="White" TextColor="Black" Clicked="OnMaintenanceClicked" />
                <Button Grid.Column="1" Text="📄 Contract" BackgroundColor="White" TextColor="Black" />
            </Grid>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>