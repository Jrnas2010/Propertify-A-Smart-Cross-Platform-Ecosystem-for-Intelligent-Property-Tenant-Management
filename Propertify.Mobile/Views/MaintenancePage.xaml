<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Propertify.Mobile.Views.MaintenancePage"
             Title="Maintenance"
             BackgroundColor="#f8fafc">

    <Shell.TitleView>
        <Label Text="Maintenance" FontSize="18" FontAttributes="Bold"
               TextColor="White" VerticalOptions="Center" Margin="4,0,0,0"/>
    </Shell.TitleView>

    <Grid RowDefinitions="Auto,Auto,*,Auto">

        <!-- Header -->
        <Border Grid.Row="0" BackgroundColor="#1e3a5f" Padding="20,36,20,20" StrokeThickness="0">
            <VerticalStackLayout Spacing="4">
                <Label Text="MAINTENANCE REQUESTS" FontSize="10" FontAttributes="Bold"
                       TextColor="#93c5fd" CharacterSpacing="1.5"/>
                <Label Text="Track your service requests" FontSize="20" FontAttributes="Bold" TextColor="White"/>
            </VerticalStackLayout>
        </Border>

        <!-- Filter chips -->
        <ScrollView Grid.Row="1" Orientation="Horizontal"
                    HorizontalScrollBarVisibility="Never"
                    Padding="16,12">
            <HorizontalStackLayout Spacing="8" x:Name="FilterChips">
                <Border x:Name="ChipAll" Padding="16,8" StrokeThickness="0" BackgroundColor="#1e3a5f">
                    <Border.StrokeShape><RoundRectangle CornerRadius="20"/></Border.StrokeShape>
                    <Label Text="All" FontSize="12" FontAttributes="Bold" TextColor="White"/>
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnFilterAll"/>
                    </Border.GestureRecognizers>
                </Border>
                <Border x:Name="ChipPending" Padding="16,8" StrokeThickness="1" BackgroundColor="White">
                    <Border.Stroke><SolidColorBrush Color="#e2e8f0"/></Border.Stroke>
                    <Border.StrokeShape><RoundRectangle CornerRadius="20"/></Border.StrokeShape>
                    <Label Text="Pending" FontSize="12" FontAttributes="Bold" TextColor="#64748b"/>
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnFilterPending"/>
                    </Border.GestureRecognizers>
                </Border>
                <Border x:Name="ChipInProgress" Padding="16,8" StrokeThickness="1" BackgroundColor="White">
                    <Border.Stroke><SolidColorBrush Color="#e2e8f0"/></Border.Stroke>
                    <Border.StrokeShape><RoundRectangle CornerRadius="20"/></Border.StrokeShape>
                    <Label Text="In Progress" FontSize="12" FontAttributes="Bold" TextColor="#64748b"/>
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnFilterInProgress"/>
                    </Border.GestureRecognizers>
                </Border>
                <Border x:Name="ChipDone" Padding="16,8" StrokeThickness="1" BackgroundColor="White">
                    <Border.Stroke><SolidColorBrush Color="#e2e8f0"/></Border.Stroke>
                    <Border.StrokeShape><RoundRectangle CornerRadius="20"/></Border.StrokeShape>
                    <Label Text="Done" FontSize="12" FontAttributes="Bold" TextColor="#64748b"/>
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnFilterDone"/>
                    </Border.GestureRecognizers>
                </Border>
            </HorizontalStackLayout>
        </ScrollView>

        <!-- List -->
        <RefreshView Grid.Row="2"
                     IsRefreshing="{Binding IsRefreshing}"
                     Command="{Binding RefreshCommand}">
            <CollectionView ItemsSource="{Binding Requests}"
                            BackgroundColor="Transparent" Margin="0,4">

                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <Border BackgroundColor="White" Margin="16,0,16,12"
                                Padding="16" StrokeThickness="0">
                            <Border.StrokeShape><RoundRectangle CornerRadius="16"/></Border.StrokeShape>
                            <Border.Shadow><Shadow Brush="Black" Offset="0,2" Radius="8" Opacity="0.06"/></Border.Shadow>

                            <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="14">
                                <!-- Icon -->
                                <Border Grid.Column="0" BackgroundColor="#fff7ed"
                                        WidthRequest="46" HeightRequest="46" StrokeThickness="0">
                                    <Border.StrokeShape><RoundRectangle CornerRadius="13"/></Border.StrokeShape>
                                    <Label Text="🔧" FontSize="20"
                                           HorizontalOptions="Center" VerticalOptions="Center"/>
                                </Border>

                                <!-- Info -->
                                <VerticalStackLayout Grid.Column="1" Spacing="4" VerticalOptions="Center">
                                    <Label Text="{Binding Title}" FontSize="14"
                                           FontAttributes="Bold" TextColor="#0f172a"/>
                                    <Label Text="{Binding Description}" FontSize="12"
                                           TextColor="#64748b" LineBreakMode="TailTruncation"
                                           MaxLines="1"/>
                                    <Label Text="{Binding CreatedAt}" FontSize="11" TextColor="#94a3b8"/>
                                </VerticalStackLayout>

                                <!-- Priority + Status -->
                                <VerticalStackLayout Grid.Column="2" Spacing="6" HorizontalOptions="End">
                                    <Border Padding="8,3" StrokeThickness="0" HorizontalOptions="End">
                                        <Border.StrokeShape><RoundRectangle CornerRadius="20"/></Border.StrokeShape>
                                        <Label Text="{Binding Status}" FontSize="10"
                                               FontAttributes="Bold" TextColor="White"/>
                                        <Border.BackgroundColor>
                                            <Binding Path="Status" Converter="{StaticResource StatusToColorConverter}"/>
                                        </Border.BackgroundColor>
                                    </Border>
                                    <Border Padding="8,3" StrokeThickness="0" HorizontalOptions="End"
                                            BackgroundColor="#f1f5f9">
                                        <Border.StrokeShape><RoundRectangle CornerRadius="20"/></Border.StrokeShape>
                                        <Label Text="{Binding Priority}" FontSize="10"
                                               FontAttributes="Bold" TextColor="#475569"/>
                                    </Border>
                                </VerticalStackLayout>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </CollectionView.ItemTemplate>

                <CollectionView.EmptyView>
                    <VerticalStackLayout HorizontalOptions="Center" VerticalOptions="Center"
                                         Spacing="12" Padding="40">
                        <Label Text="🔧" FontSize="48" HorizontalOptions="Center"/>
                        <Label Text="No Requests Found" FontSize="16" FontAttributes="Bold"
                               TextColor="#0f172a" HorizontalOptions="Center"/>
                        <Label Text="Submit a maintenance request using the button below."
                               FontSize="13" TextColor="#94a3b8" HorizontalOptions="Center"
                               HorizontalTextAlignment="Center"/>
                    </VerticalStackLayout>
                </CollectionView.EmptyView>
            </CollectionView>
        </RefreshView>

        <!-- Loading -->
        <ActivityIndicator Grid.Row="2" IsRunning="{Binding IsBusy}"
                           IsVisible="{Binding IsBusy}"
                           Color="#3b82f6" VerticalOptions="Center" HorizontalOptions="Center"/>

        <!-- Add button -->
        <Button Grid.Row="3"
                Text="+ New Maintenance Request"
                BackgroundColor="#1e3a5f" TextColor="White"
                CornerRadius="14" HeightRequest="52"
                FontSize="14" FontAttributes="Bold"
                Margin="16,8,16,20"
                Clicked="OnAddClicked"/>
    </Grid>
</ContentPage>
