@{
    Layout = "_PublicLayout";
    ViewData["Title"] = " Login | Propertify";
}

<div class="container-fluid vh-100 p-0 overflow-hidden" dir="rtl">
    <div class="row g-0 h-100">
        <div class="col-lg-7 d-none d-lg-block position-relative">
            <div class="position-absolute top-0 start-0 w-100 h-100" 
                 style="background: linear-gradient(rgba(44, 62, 80, 0.7), rgba(44, 62, 80, 0.7)), 
                        url('https://images.unsplash.com/photo-1512917774080-9991f1c4c750?auto=format&fit=crop&w=1350&q=80') no-repeat center center; 
                        background-size: cover;">
            </div>
            <div class="position-absolute bottom-0 start-0 p-5 text-white animate__animated animate__fadeInUp">
                <h1 class="display-4 fw-bold">Welcome to <span class="text-primary-light">Propertify</span></h1>
                <p class="fs-5 opacity-75">Manage your properties with ease like never before.</p>
            </div>
        </div>

        <div class="col-lg-5 col-md-12 bg-white d-flex align-items-center justify-content-center p-5">
            <div class="w-100" style="max-width: 400px;">
                <div class="text-center mb-5">
                    <img src="/images/logo-dark.png" alt="Propertify Logo" class="mb-4" width="120">
                    <h3 class="fw-bold text-dark">Login</h3>
                    <p class="text-muted">Enter your credentials to access the control panel</p>
                </div>

                <form asp-action="Login" method="post" class="animate__animated animate__fadeIn">
                    <div class="mb-3">
                        <label class="form-label fw-bold small">Email</label>
                        <div class="input-group">
                            <span class="input-group-text bg-light border-0"><i class="fas fa-envelope text-muted"></i></span>
                            <input type="email" name="Email" class="form-control bg-light border-0 shadow-none" placeholder="name@example.com" required>
                        </div>
                    </div>

                    <div class="mb-3">
                        <div class="d-flex justify-content-between">
                            <label class="form-label fw-bold small">Password</label>
                            <a href="#" class="small text-decoration-none">Forgot Password?</a>
                        </div>
                        <div class="input-group">
                            <span class="input-group-text bg-light border-0"><i class="fas fa-lock text-muted"></i></span>
                            <input type="password" name="Password" class="form-control bg-light border-0 shadow-none" placeholder="••••••••" required>
                        </div>
                    </div>

                    <div class="mb-4 form-check text-end">
                        <input type="checkbox" class="form-check-input float-none ms-2" id="remember">
                        <label class="form-check-label small" for="remember">Remember me on this device</label>
                    </div>

                    <button type="submit" class="btn btn-primary w-100 rounded-pill py-3 fw-bold shadow-sm mb-4">
                       Login To The System
                    </button>

                    <div class="text-center">
                        <p class="text-muted small">You don't have an account? <a asp-action="Register" class="fw-bold text-primary text-decoration-none">Create a new account</a></p>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

<style>
    .text-primary-light { color: #5dade2 !important; }
    .btn-primary { background-color: #2c3e50; border: none; transition: all 0.3s; }
    .btn-primary:hover { background-color: #1a252f; transform: translateY(-2px); }
    .form-control { padding: 12px; }
    .input-group-text { padding: 12px; }
</style>