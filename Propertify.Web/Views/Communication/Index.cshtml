@{
    ViewData["Title"] = "Communication Center - Propertify";
}

<div class="container-fluid py-4">
    <div class="mb-4">
        <h3 class="fw-bold text-primary">Communication Center</h3>
        <p class="text-muted small">Send alerts and notifications directly to tenants' phones</p>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show border-0 shadow-sm rounded-3" role="alert">
            <i class="fas fa-check-circle me-2"></i> @TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <div class="row g-4 mb-5">
        <!-- Message Creation Section -->
        <div class="col-lg-7">
            <div class="card border-0 shadow-sm p-4 rounded-4">
                <form asp-action="SendMessage" method="post">
                    @Html.AntiForgeryToken()
                    <div class="mb-4">
                        <label class="form-label fw-bold">Select Recipients</label>
                        <select class="form-select form-select-lg fs-6 border-light-subtle" name="target">
                            <option value="all">All Tenants (Across All Properties)</option>
                            <option value="building1">Tenants in Building A Only</option>
                            <option value="building2">Tenants in Building B Only</option>
                        </select>
                        <div class="form-text">The message will be sent as a notification on the tenant's phone app.</div>
                    </div>

                    <div class="mb-3">
                        <label class="form-label fw-bold">Message Subject</label>
                        <input type="text" name="subject" id="msgSubject" class="form-control border-light-subtle" placeholder="e.g., Temporary Water Shutdown Alert" required>
                    </div>

                    <div class="mb-4">
                        <label class="form-label fw-bold">Message Content</label>
                        <textarea name="message" id="msgContent" class="form-control border-light-subtle" rows="6" placeholder="Enter message details here..." required></textarea>
                    </div>

                    <button type="submit" class="btn btn-primary px-5 py-2 rounded-3 shadow-sm">
                        <i class="fas fa-paper-plane me-2"></i> Send Notification Now
                    </button>
                </form>
            </div>
        </div>

        <!-- Phone Preview Section -->
        <div class="col-lg-5">
            <div class="card border-0 shadow-sm p-4 bg-light h-100 rounded-4 border border-white">
                <h5 class="fw-bold mb-4 text-center">Live Preview on Phone</h5>
                <div class="smartphone-mockup mx-auto shadow-lg border border-4 border-dark rounded-5" style="width: 250px; height: 450px; background: #f8f9fa; position: relative; overflow: hidden;">
                    <div class="p-3">
                        <!-- Notification Toast -->
                        <div class="bg-white text-dark rounded-3 p-2 mb-2 shadow-sm border-start border-primary border-4">
                            <div class="d-flex justify-content-between align-items-center">
                                <span class="fw-bold text-primary" style="font-size: 10px;"><i class="fas fa-building me-1"></i> Propertify</span>
                                <span class="text-muted" style="font-size: 8px;">Now</span>
                            </div>
                            <div id="previewSubject" style="font-size: 10px; font-weight: 600;" class="mt-1">Message subject...</div>
                            <div id="previewContent" style="font-size: 9px;" class="text-muted text-truncate mt-1">Message content will appear here...</div>
                        </div>
                        
                        <div class="text-center mt-5">
                            <h2 class="text-dark opacity-25">12:45</h2>
                            <p class="text-muted small">Monday, May 4</p>
                            <i class="fas fa-lock fa-2x text-dark opacity-10 mt-5"></i>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- NEW SECTION: Broadcast History Table -->
    <div class="mb-4 pt-2">
        <h4 class="fw-bold"><i class="fas fa-history me-2 text-primary"></i> Sent Broadcast History</h4>
        <p class="text-muted small">Track and reuse previous notifications sent to tenants</p>
    </div>

    <div class="card border-0 shadow-sm rounded-4 overflow-hidden mb-5">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-light">
                    <tr>
                        <th class="ps-4">Sent Date</th>
                        <th>Target Group</th>
                        <th>Subject</th>
                        <th>Content Preview</th>
                        <th class="text-end pe-4">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @{
                        var sentMessages = ViewBag.SentMessages as List<Propertify.Web.Models.SystemMessage> ?? new();
                    }
                    @if (!sentMessages.Any())
                    {
                        <tr>
                            <td colspan="5" class="text-center text-muted py-4">No messages sent yet.</td>
                        </tr>
                    }
                    @foreach (var msg in sentMessages)
                    {
                        <tr>
                            <td class="ps-4 small text-muted">@msg.SentAt.ToString("MMM dd, yyyy HH:mm")</td>
                            <td><span class="badge bg-primary-subtle text-primary rounded-pill">@msg.Target</span></td>
                            <td class="fw-bold">@msg.Subject</td>
                            <td class="text-muted small text-truncate" style="max-width: 300px;">@msg.Content</td>
                            <td class="text-end pe-4">
                                <button class="btn btn-sm btn-outline-primary rounded-pill px-3"
                                        onclick="resendMessage('@Html.Raw(System.Text.Json.JsonSerializer.Serialize(msg.Subject))', '@Html.Raw(System.Text.Json.JsonSerializer.Serialize(msg.Content))')">
                                    <i class="fas fa-redo me-1"></i> Resend
                                </button>
                                <form asp-action="DeleteMessage" method="post" class="d-inline"
                                      onsubmit="return confirm('Delete this message?');">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="id" value="@msg.MessageId" />
                                    <button type="submit" class="btn btn-sm btn-light rounded-circle ms-1">
                                        <i class="fas fa-trash-alt text-danger"></i>
                                    </button>
                                </form>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

<style>
    .form-control:focus, .form-select:focus {
        border-color: #3498db;
        box-shadow: 0 0 0 0.2rem rgba(52, 152, 219, 0.1);
    }
    .smartphone-mockup::before {
        content: "";
        position: absolute;
        top: 12px;
        left: 50%;
        transform: translateX(-50%);
        width: 60px;
        height: 6px;
        background: #333;
        border-radius: 10px;
    }
    .table thead th { font-size: 12px; text-transform: uppercase; letter-spacing: 0.5px; padding: 15px; }
    .table tbody td { padding: 15px; }
</style>

<script>
    // Live Preview Script
    document.getElementById('msgSubject').addEventListener('input', function(e) {
        document.getElementById('previewSubject').innerText = e.target.value || "Message subject...";
    });
    
    document.getElementById('msgContent').addEventListener('input', function(e) {
        document.getElementById('previewContent').innerText = e.target.value || "Message content will appear here...";
    });

    function resendMessage(subjectJson, contentJson) {
        const subject = JSON.parse(subjectJson) ?? '';
        const content = JSON.parse(contentJson) ?? '';
        document.getElementById('msgSubject').value = subject;
        document.getElementById('msgContent').value = content;
        document.getElementById('previewSubject').textContent = subject || 'Message subject...';
        document.getElementById('previewContent').textContent = content || 'Message content will appear here...';
        window.scrollTo({ top: 0, behavior: 'smooth' });
    }
</script>