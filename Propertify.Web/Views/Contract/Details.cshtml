@model Propertify.Web.Models.Contract
@{
    ViewData["Title"] = "Contract Details";
}

<div class="container-fluid py-4" dir="rtl" style="max-width: 100%; padding-left: 1rem; padding-right: 1rem;">
    <!-- Header -->
    <div class="d-flex justify-content-between align-items-center mb-4 flex-wrap gap-2">
        <div>
            <h3 class="fw-bold text-primary mb-0"><i class="fas fa-file-signature ms-2"></i>Lease Contract Details</h3>
            <p class="text-muted small mb-0">Contract #@Model.Id for @Model.Tenant?.FullNameAr</p>
        </div>
        <div class="d-flex gap-2">
            <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-warning rounded-pill px-4 shadow-sm">
                <i class="fas fa-edit ms-1"></i> Edit
            </a>
            <a asp-action="Index" class="btn btn-outline-secondary rounded-pill px-4 shadow-sm">
                <i class="fas fa-arrow-left ms-1"></i> Back to List
            </a>
        </div>
    </div>

    <div class="row g-4">
        <!-- Main Contract Info -->
        <div class="col-lg-8">
            <div class="card border-0 shadow-sm rounded-4 overflow-hidden h-100">
                <div class="card-header bg-primary text-white p-3 border-0">
                    <h5 class="mb-0 fw-bold"><i class="fas fa-info-circle ms-2"></i>Contract Terms</h5>
                </div>
                <div class="card-body p-4">
                    <div class="row g-4">
                        <div class="col-md-6">
                            <label class="text-muted small d-block mb-1">Start Date</label>
                            <p class="fw-bold fs-5 text-dark mb-0">@Model.StartDate.ToString("yyyy-MM-dd")</p>
                        </div>
                        <div class="col-md-6">
                            <label class="text-muted small d-block mb-1">End Date</label>
                            <p class="fw-bold fs-5 text-dark mb-0">@Model.EndDate.ToString("yyyy-MM-dd")</p>
                        </div>
                        <div class="col-md-6">
                            <label class="text-muted small d-block mb-1">Total Rent Amount</label>
                            <p class="fw-bold fs-4 text-primary mb-0">@Model.RentAmount.ToString("N3") OMR</p>
                        </div>
                        <div class="col-md-6">
                            <label class="text-muted small d-block mb-1">Monthly Rent</label>
                            <p class="fw-bold fs-4 text-primary mb-0">@Model.MonthlyRent.ToString("N3") OMR</p>
                        </div>
                        <div class="col-md-6">
                            <label class="text-muted small d-block mb-1">Current Status</label>
                            @{
                                var daysToExpiry = (Model.EndDate - DateTime.Now).Days;
                                var badgeClass = "bg-success-subtle text-success";
                                var statusText = Model.Status;

                                if (daysToExpiry <= 90 && daysToExpiry > 0)
                                {
                                    badgeClass = "bg-warning-subtle text-warning";
                                    statusText = "Expiring Soon";
                                }
                                else if (daysToExpiry <= 0)
                                {
                                    badgeClass = "bg-danger-subtle text-danger";
                                    statusText = "Expired";
                                }
                            }
                            <span class="badge @badgeClass rounded-pill px-4 fs-6">@statusText</span>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Tenant & Unit Info -->
        <div class="col-lg-4">
            <div class="row g-4">
                <!-- Tenant Card -->
                <div class="col-12">
                    <div class="card border-0 shadow-sm rounded-4">
                        <div class="card-header bg-dark text-white p-3 border-0">
                            <h5 class="mb-0 fw-bold"><i class="fas fa-user ms-2"></i>Tenant</h5>
                        </div>
                        <div class="card-body p-4">
                            <div class="d-flex align-items-center mb-3">
                                <div class="bg-light rounded-circle p-3 me-3">
                                    <i class="fas fa-user-tie fa-lg text-primary"></i>
                                </div>
                                <div>
                                    <h6 class="fw-bold mb-0">@Model.Tenant?.FullNameAr</h6>
                                    <small class="text-muted">ID: @Model.Tenant?.IdNumber</small>
                                </div>
                            </div>
                            <a asp-controller="Tenant" asp-action="Details" asp-route-id="@Model.TenantId" class="btn btn-sm btn-outline-primary w-100 rounded-pill">
                                View Tenant Profile
                            </a>
                        </div>
                    </div>
                </div>

                <!-- Unit Card -->
                <div class="col-12">
                    <div class="card border-0 shadow-sm rounded-4">
                        <div class="card-header bg-info text-white p-3 border-0">
                            <h5 class="mb-0 fw-bold"><i class="fas fa-building ms-2"></i>Property & Unit</h5>
                        </div>
                        <div class="card-body p-4">
                            <div class="mb-3">
                                <label class="text-muted small d-block mb-1">Property</label>
                                <p class="fw-bold mb-2">@Model.Unit?.Property?.Name</p>
                                <label class="text-muted small d-block mb-1">Unit Number</label>
                                <p class="fw-bold mb-0">Unit @Model.Unit?.UnitNumber (Floor @Model.Unit?.FloorNumber)</p>
                            </div>
                            <a asp-controller="Property" asp-action="Details" asp-route-id="@Model.Unit?.PropertyId" class="btn btn-sm btn-outline-info w-100 rounded-pill text-white">
                                View Property Details
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
