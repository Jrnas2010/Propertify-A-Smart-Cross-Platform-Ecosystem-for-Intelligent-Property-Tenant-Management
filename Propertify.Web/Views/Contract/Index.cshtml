@model IEnumerable<Propertify.Web.Models.Contract>

<div class="card border-0 shadow-sm rounded-4 p-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h5 class="fw-bold"><i class="fas fa-file-contract text-primary me-2"></i>Lease Contracts Management</h5>
        <a asp-action="Create" class="btn btn-primary rounded-pill px-4">
            <i class="fas fa-plus me-1"></i> New Contract
        </a>
    </div>

    <div class="table-responsive">
        <table class="table table-hover align-middle">
            <div class="row mb-4">
                <div class="col-md-8">
                    <form asp-action="Index" method="get" class="d-flex gap-2">
                        <div class="input-group shadow-sm">
                            <span class="input-group-text bg-white border-end-0">
                                <i class="fas fa-search text-muted"></i>
                            </span>
                            <input type="text" name="searchTerm" value="@ViewBag.SearchTerm" 
                                class="form-control border-start-0 ps-0 rounded-end" 
                                placeholder="Search by Tenant Name or Unit Number...">
                        </div>
                        <button type="submit" class="btn btn-primary px-4 rounded-pill shadow-sm">Search</button>
                        @if (!string.IsNullOrEmpty(ViewBag.SearchTerm as string))
                        {
                            <a asp-action="Index" class="btn btn-outline-secondary rounded-pill shadow-sm">
                                <i class="fas fa-times"></i> Clear
                            </a>
                        }
                    </form>
                </div>
                <div class="col-md-4 text-end">
                    <div class="dropdown">
                        <button class="btn btn-white border shadow-sm dropdown-toggle rounded-pill" type="button" data-bs-toggle="dropdown">
                            <i class="fas fa-filter me-1"></i> Filter Status
                        </button>
                        <ul class="dropdown-menu">
                            <li><a class="dropdown-menu" href="#">All Contracts</a></li>
                            <li><a class="dropdown-item text-warning" href="#">Expiring Soon (3 Months)</a></li>
                            <li><a class="dropdown-item text-danger" href="#">Expired</a></li>
                        </ul>
                    </div>
                </div>
            </div>
            <thead class="bg-light">
                <tr>
                    <th>Tenant Details</th>
                    <th>Unit Information</th>
                    <th>Rent (OMR)</th>
                    <th>Lease Duration</th>
                    <th>Status</th>
                    <th class="text-center">Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    // منطق حساب التنبيه اللوني (90 يوم = 3 أشهر)
                    var daysToExpiry = (item.EndDate - DateTime.Now).Days;
                    var rowStyle = "";
                    var badgeClass = "bg-success-subtle text-success";
                    var statusText = "Active";

                    if (daysToExpiry <= 90 && daysToExpiry > 0)
                    {
                        rowStyle = "table-warning"; // تنبيه برتقالي/أصفر
                        badgeClass = "bg-warning-subtle text-warning-emphasis";
                        statusText = "Expiring Soon";
                    }
                    else if (daysToExpiry <= 0)
                    {
                        rowStyle = "table-danger"; // تنبيه أحمر للمنتهي
                        badgeClass = "bg-danger-subtle text-danger";
                        statusText = "Expired";
                    }

                    <tr class="@rowStyle">
                        <td>
                            <div class="fw-bold">@item.Tenant?.FirstNameAr @item.Tenant?.LastNameAr</div>
                            <small class="text-muted">ID: @item.Tenant?.IdNumber</small>
                        </td>
                        <td>
                            <span class="badge bg-light text-dark border">
                                <i class="fas fa-door-open me-1"></i> Unit @item.Unit?.UnitNumber
                            </span>
                        </td>
                        <td class="fw-bold text-primary">
                            @item.RentAmount.ToString("N2") <small>OMR</small>
                        </td>
                        <td>
                            <div class="small">@item.StartDate.ToShortDateString()</div>
                            <div class="small text-muted text-decoration-underline">@item.EndDate.ToShortDateString()</div>
                        </td>
                        <td>
                            <span class="badge @badgeClass rounded-pill px-3">
                                <i class="fas fa-circle fst-normal me-1" style="font-size: 8px;"></i> @statusText
                            </span>
                        </td>
                        <td class="text-center">
                            <div class="btn-group">
                                <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-white border rounded-circle me-1 shadow-sm">
                                    <i class="fas fa-edit text-primary"></i>
                                </a>
                                <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-white border rounded-circle me-1 shadow-sm">
                                    <i class="fas fa-eye text-info"></i>
                                </a>
                                <button class="btn btn-sm btn-white border text-danger rounded-circle shadow-sm">
                                    <i class="fas fa-trash"></i>
                                </button>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>