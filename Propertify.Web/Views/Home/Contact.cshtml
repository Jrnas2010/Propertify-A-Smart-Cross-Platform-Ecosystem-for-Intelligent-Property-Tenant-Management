@{
    ViewData["Title"] = "Contact Us - Get in Touch with Propertify";
}

<div class="container py-5">
    <div class="row g-5">
        <div class="col-md-6">
            <h2 class="fw-bold text-primary mb-4">Contact Us</h2>
            <p class="text-muted">Do you have a question about a specific property? Our team is ready to assist you as soon as possible.</p>

            <div class="mt-4">
                <p><i class="fas fa-phone-alt text-primary ms-3"></i> +968 24XXXXXX</p>
                <p><i class="fas fa-envelope text-primary ms-3"></i> info@propertify.com</p>
                <p><i class="fas fa-map-marked-alt text-primary ms-3"></i> Muscat, Sultanate of Oman - Airport Road</p>
            </div>

            <hr class="my-5">

            <div class="bg-light p-4 rounded-3 text-center border border-dashed">
                <h5>Are you a current tenant?</h5>
                <p class="small text-muted">Sign in to submit maintenance requests</p>
                <a asp-controller="Account" asp-action="Login" class="btn btn-dark px-4">Sign In</a>
            </div>
        </div>

        <div class="col-md-6">
            <div class="card border-0 shadow p-4">
                <form>
                    <div class="mb-3">
                        <label class="form-label fw-bold">Full Name</label>
                        <input type="text" class="form-control" required>
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-bold">Email Address</label>
                        <input type="email" class="form-control" required>
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-bold">Message</label>
                        <textarea class="form-control" rows="5" required></textarea>
                    </div>
                    <button type="submit" class="btn btn-primary w-100 py-2">Send Message</button>
                </form>
            </div>
        </div>
    </div>
</div>