@model Propertify.Web.Models.Unit
@{
    Layout = "_PublicLayout";
    ViewData["Title"] = $"Unit {Model.UnitNumber} Details | Propertify";
    var images = !string.IsNullOrEmpty(Model.UnitImages) 
                 ? Model.UnitImages.Split(',').ToList() 
                 : new List<string> { "/images/default-unit.png" };
}

<div class="container py-5" dir="rtl">
    <nav aria-label="breadcrumb" class="mb-4">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a asp-action="Index">Home</a></li>
            <li class="breadcrumb-item"><a asp-action="AllUnits">Units</a></li>
            <li class="breadcrumb-item active">Unit @Model.UnitNumber</li>
        </ol>
    </nav>

    <div class="row">
        <!-- Image Gallery -->
        <div class="col-lg-7 mb-4">
            <div class="card border-0 shadow-sm rounded-4 overflow-hidden mb-3">
                <img id="mainImage" src="@images[0]" class="img-fluid w-100" style="height: 450px; object-fit: cover;" alt="Unit View">
            </div>
            @if (images.Count > 1)
            {
                <div class="row g-2">
                    @foreach (var img in images)
                    {
                        <div class="col-3">
                            <img src="@img" class="img-fluid rounded-3 shadow-sm clickable-img" style="height: 80px; object-fit: cover; cursor: pointer;" onclick="document.getElementById('mainImage').src=this.src">
                        </div>
                    }
                </div>
            }
        </div>

        <!-- Details Sidebar -->
        <div class="col-lg-5">
            <div class="card border-0 shadow-sm rounded-4 p-4 sticky-top" style="top: 100px;">
                <div class="d-flex justify-content-between align-items-start mb-3">
                    <div>
                        <h2 class="fw-bold mb-1">Unit @Model.UnitNumber</h2>
                        <h5 class="text-primary mb-0">@Model.Property?.Name</h5>
                    </div>
                    <span class="badge bg-success-subtle text-success rounded-pill px-3 py-2">Available Now</span>
                </div>

                <p class="text-muted mb-4 small"><i class="fas fa-map-marker-alt ms-1 text-danger"></i> @Model.Property?.Location</p>
                
                <div class="bg-light p-4 rounded-4 mb-4">
                    <div class="row text-center g-3">
                        <div class="col-4">
                            <i class="fas fa-bed text-primary mb-2 fs-4"></i>
                            <p class="small text-muted mb-0">Bedrooms</p>
                            <p class="fw-bold mb-0">@Model.Bedrooms</p>
                        </div>
                        <div class="col-4 border-start border-end">
                            <i class="fas fa-bath text-primary mb-2 fs-4"></i>
                            <p class="small text-muted mb-0">Bathrooms</p>
                            <p class="fw-bold mb-0">@Model.Bathrooms</p>
                        </div>
                        <div class="col-4">
                            <i class="fas fa-expand-arrows-alt text-primary mb-2 fs-4"></i>
                            <p class="small text-muted mb-0">Area</p>
                            <p class="fw-bold mb-0">@Model.Area m²</p>
                        </div>
                    </div>
                </div>

                <div class="mb-4">
                    <h4 class="fw-bold text-dark mb-1">@Model.RentAmount.ToString("N3") OMR</h4>
                    <p class="text-muted small">Monthly Rental Amount (Standard Contract)</p>
                </div>

                <div class="mb-4">
                    <h6 class="fw-bold border-bottom pb-2 mb-3">Unit Features</h6>
                    <ul class="list-unstyled row g-2">
                        <li class="col-6 small"><i class="fas fa-check text-success ms-2"></i> Floor @Model.FloorNumber</li>
                        <li class="col-6 small"><i class="fas fa-check text-success ms-2"></i> @Model.Kitchens Kitchens</li>
                        <li class="col-6 small"><i class="fas fa-check text-success ms-2"></i> @Model.LivingRooms Living Rooms</li>
                        @if (Model.Majlis > 0)
                        {
                            <li class="col-6 small"><i class="fas fa-check text-success ms-2"></i> @Model.Majlis Majlis</li>
                        }
                    </ul>
                </div>

                <a asp-action="Inquiry" asp-route-unit="@Model.UnitNumber" class="btn btn-primary btn-lg rounded-pill w-100 fw-bold py-3 shadow">
                    Book This Unit Now
                </a>
            </div>
        </div>
    </div>
</div>

<style>
    .clickable-img:hover { opacity: 0.8; }
</style>