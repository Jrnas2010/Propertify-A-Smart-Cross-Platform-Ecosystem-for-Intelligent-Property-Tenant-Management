@model IEnumerable<Propertify.Web.Models.Property>
@{
    Layout = "_PublicLayout";
    ViewData["Title"] = "Home Page | Propertify";
    var availableUnits = ViewBag.AvailableUnits as IEnumerable<Propertify.Web.Models.Unit>;
}

<header class="hero-section py-5 position-relative overflow-hidden" style="background: linear-gradient(rgba(0,0,0,0.65), rgba(0,0,0,0.65)), url('https://images.unsplash.com/photo-1560518883-ce09059eeffa?auto=format&fit=crop&w=1350&q=80') no-repeat center center; background-size: cover; min-height: 80vh; display: flex; align-items: center;">
    <div class="container text-center text-white animate__animated animate__fadeIn">
        <h1 class="display-3 fw-bold mb-3">Manage Your Property <span class="text-primary-custom">Smarter.</span></h1>
        <p class="lead mb-5 px-lg-5">The ultimate solution for property management in the Sultanate of Oman. Track your units, tenants, and financial growth in one place.</p>
        
        <div class="search-container mx-auto" style="max-width: 800px;">
            <form asp-action="Search" asp-controller="Home" method="get">
                <div class="input-group input-group-lg shadow-lg rounded-pill overflow-hidden bg-white p-1">
                    <span class="input-group-text bg-transparent border-0 ps-4">
                        <i class="fas fa-search text-muted"></i>
                    </span>
                    <input type="text" name="query" class="form-control border-0 shadow-none fs-6" placeholder="Search for a location, property name, or unit number...">
                    <button class="btn btn-primary rounded-pill px-5 fw-bold" type="submit">Search</button>
                </div>
            </form>
            <div class="mt-3">
                <span class="small opacity-75">Popular Searches: Al Khoud, Seeb, Commercial Offices, Residential Apartments</span>
            </div>
        </div>
    </div>
</header>

<main class="container py-5 mt-4 text-end" dir="rtl">
    
    <div class="d-flex justify-content-between align-items-end mb-4 border-bottom pb-3">
        <div>
            <h6 class="text-primary fw-bold text-uppercase mb-1 small">Our Portfolio</h6>
            <h2 class="fw-bold mb-0">Available Properties and Facilities</h2>
        </div>
        <div class="dropdown">
            <button class="btn btn-outline-dark dropdown-toggle rounded-pill px-4" type="button" data-bs-toggle="dropdown">
                <i class="fas fa-filter me-2"></i> Filter by
            </button>
            <ul class="dropdown-menu shadow-sm border-0">
                <li><a class="dropdown-item" href="#" onclick="filterProperties('سكني')">Residential</a></li>
                <li><a class="dropdown-item" href="#" onclick="filterProperties('تجاري')">Commercial</a></li>
                <li><hr class="dropdown-divider"></li>
                <li><a class="dropdown-item" href="#" onclick="filterProperties('all')">All</a></li>
            </ul>
        </div>
    </div>

    <div class="row g-4 mb-5" id="propertyGrid">
        @if (Model != null && Model.Any())
        {
            @foreach (var property in Model)
            {
                <div class="col-md-4 property-card-wrapper" data-type="@property.Type">
                    <div class="card border-0 shadow-sm h-100 property-card rounded-4 overflow-hidden">
                        <div class="position-relative">
                            <img src="@(string.IsNullOrEmpty(property.ImagePath) ? "/images/default-building.png" : property.ImagePath)" 
                                 class="card-img-top" style="height: 220px; object-fit: cover;" alt="@property.Name">
                            <span class="badge bg-primary position-absolute top-0 end-0 m-3 px-3 py-2 rounded-pill shadow-sm">@property.Type</span>
                        </div>
                        <div class="card-body p-4">
                            <h5 class="fw-bold mb-1">@property.Name</h5>
                            <p class="text-muted small mb-3"><i class="fas fa-map-marker-alt text-danger ms-1"></i> @property.Location</p>
                            <div class="d-flex justify-content-between align-items-center border-top pt-3">
                                <span class="text-primary-custom fw-bold">@property.TotalUnits Units</span>
                                <a asp-action="Details" asp-controller="Property" asp-route-id="@property.Id" class="btn btn-sm btn-outline-primary px-4 rounded-pill">Details</a>
                            </div>
                        </div>
                    </div>
                </div>
            }
        }
    </div>

    <section id="units" class="py-5 bg-light rounded-5 px-4 mb-5 shadow-sm">
        <div class="d-flex justify-content-between align-items-end mb-5">
            <div>
                <h6 class="text-primary fw-bold text-uppercase mb-1 small">Featured Units</h6>
                <h2 class="fw-bold mb-0">Find Your Next Space</h2>
            </div>
            <a href="/Home/AllUnits" class="btn btn-dark rounded-pill px-4 shadow-sm">View All Units</a>
        </div>

        <div class="row g-4">
            @if (availableUnits != null && availableUnits.Any())
            {
                @foreach (var unit in availableUnits)
                {
                    <div class="col-lg-4 col-md-6">
                        <div class="card border-0 shadow-sm rounded-4 overflow-hidden h-100 unit-card">
                            <div class="position-relative">
                            <img src="@(string.IsNullOrEmpty(unit.UnitImages) ? "/images/default-unit.jpg" : unit.UnitImages.Split(',')[0])" 
                                     class="card-img-top" style="height: 240px; object-fit: cover;" alt="Unit Image">
                                <span class="badge bg-success position-absolute top-0 end-0 m-3 rounded-pill px-3 py-2">Available Now</span>
                            </div>
                            
                            <div class="card-body p-4">
                                <h5 class="fw-bold mb-1">Unit @unit.UnitNumber - @unit.Property?.Name</h5>
                                <p class="text-muted small mb-3"><i class="fas fa-map-marker-alt ms-1"></i> @unit.Property?.Location</p>
                                
                                <div class="d-flex justify-content-between align-items-center mt-3 pt-3 border-top">
                                    <div class="text-primary-custom fw-bold fs-5">
                                        @unit.RentAmount <small class="text-muted fw-normal fs-6">OMR Monthly</small>
                                    </div>
                                    <a href="/Home/UnitDetails/@unit.Id" class="btn btn-dark btn-sm rounded-pill px-3">Book Now</a>
                                </div>
                            </div>
                        </div>
                    </div>
                }
            }
            else
            {
                <div class="col-12 text-center py-5">
                    <p class="text-muted italic">No available units at the moment.</p>
                </div>
            }
        </div>
    </section>
</main>

<style>
    :root { --primary-color: #2c3e50; --accent-color: #3498db; }
    .text-primary-custom { color: var(--accent-color) !important; }
    .btn-primary { background-color: var(--primary-color); border: none; }
    .btn-primary:hover { background-color: #1a252f; }
    
    .property-card, .unit-card { 
        transition: all 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275); 
        cursor: pointer; 
    }
    .property-card:hover, .unit-card:hover { 
        transform: translateY(-12px); 
        box-shadow: 0 15px 30px rgba(0,0,0,0.12) !important; 
    }
    
    .hero-section .text-primary-custom { color: #5dade2 !important; }
    .object-fit-cover { object-fit: cover; }
    
    /* Responsive adjustment for RTL */
    [dir="rtl"] .input-group > :not(:first-child):not(.dropdown-menu):not(.valid-tooltip):not(.valid-feedback):not(.invalid-tooltip):not(.invalid-feedback) {
        margin-right: -1px;
        margin-left: 0;
        border-top-left-radius: 50rem;
        border-bottom-left-radius: 50rem;
    }
</style>

@section Scripts {
    <script>
        // دالة التصفية السريعة
        function filterProperties(type) {
            const cards = document.querySelectorAll('.property-card-wrapper');
            cards.forEach(card => {
                if (type === 'all' || card.getAttribute('data-type') === type) {
                    card.style.display = 'block';
                    card.classList.add('animate__fadeIn');
                } else {
                    card.style.display = 'none';
                }
            });
        }
    </script>
}