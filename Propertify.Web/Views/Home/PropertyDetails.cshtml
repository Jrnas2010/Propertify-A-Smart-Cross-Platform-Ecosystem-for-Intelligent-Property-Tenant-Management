@{
    Layout = "_PublicLayout"; // هيدر بسيط للزوار
    ViewData["Title"] = "Property Details - Al Maha Building";
}

<div class="container py-5">
    <div class="row mb-4 align-items-end">
        <div class="col-md-8">
            <nav aria-label="breadcrumb">
                <ol class="breadcrumb mb-2">
                    <li class="breadcrumb-item"><a asp-action="Index">Home</a></li>
                    <li class="breadcrumb-item active">Al Maha Building - Al Khawr</li>
                </ol>
            </nav>
            <h1 class="fw-bold text-primary">Al Maha Residential Building</h1>
            <p class="text-muted"><i class="fas fa-map-marker-alt ms-2"></i> Muscat, Seeb, Al Khawr, Al Barakat Street</p>
        </div>
        <div class="col-md-4 text-md-start">
            <span class="badge bg-success p-2 fs-6 mb-2">Available for Rent</span>
            <h3 class="text-primary fw-bold">250 - 450 OMR <small class="text-muted fs-6">/Monthly</small></h3>
        </div>
    </div>

    <div class="row g-2 mb-5">
        <div class="col-md-8">
            <img src="https://images.unsplash.com/photo-1545324418-cc1a3fa10c00?auto=format&fit=crop&w=1000&q=80" class="img-fluid rounded-start-4 shadow-sm w-100 h-100" style="object-fit: cover;" alt="Main">
        </div>
        <div class="col-md-4 d-flex flex-column g-2">
            <img src="https://images.unsplash.com/photo-1522708323590-d24dbb6b0267?auto=format&fit=crop&w=500&q=80" class="img-fluid rounded-top-end-4 shadow-sm mb-2 h-50" style="object-fit: cover;" alt="Interior">
            <img src="https://images.unsplash.com/photo-1484154218962-a197022b5858?auto=format&fit=crop&w=500&q=80" class="img-fluid rounded-bottom-end-4 shadow-sm h-50" style="object-fit: cover;" alt="Kitchen">
        </div>
    </div>

    <div class="row g-5">
        <div class="col-md-8">
            <div class="card border-0 shadow-sm p-4 mb-4">
                <h5 class="fw-bold border-bottom pb-3 mb-3">About the Property</h5>
                <p class="text-muted lh-lg">
                    Al Maha Building is strategically located in the heart of Al Khawr, near Sultan Qaboos University and commercial centers.
                    The building is modern in design and equipped with all amenities and security features including a smart access system, surveillance cameras, and dedicated parking spaces.
                </p>
                <div class="row mt-4">
                    <div class="col-6 col-md-3 mb-3">
                        <small class="text-muted d-block small">Number of Floors</small>
                        <span class="fw-bold">4 Floors</span>
                    </div>
                    <div class="col-6 col-md-3 mb-3">
                        <small class="text-muted d-block small">Opening Date</small>
                        <span class="fw-bold">January 2024</span>
                    </div>
                    <div class="col-6 col-md-3 mb-3">
                        <small class="text-muted d-block small">Property Type</small>
                        <span class="fw-bold">Direct Management</span>
                    </div>
                </div>
            </div>

            <h5 class="fw-bold mb-3">Available Units</h5>
            <div class="card border-0 shadow-sm overflow-hidden">
                <table class="table table-hover align-middle mb-0">
                    <thead class="bg-light">
                        <tr>
                            <th class="ps-4">Unit Number</th>
                            <th>Type</th>
                            <th>Area</th>
                            <th>Price</th>
                            <th></th>
                        </tr>
                    </thead>
                    <tbody>
                        <tr>
                            <td class="ps-4 fw-bold text-primary">#102</td>
                            <td>Room and Living Room</td>
                            <td>65 m²</td>
                            <td class="fw-bold">250 OMR</td>
                            <td class="text-end pe-4"><button class="btn btn-sm btn-dark">Book Preview</button></td>
                        </tr>
                        <tr>
                            <td class="ps-4 fw-bold text-primary">#305</td>
                            <td>Room and Living Room</td>
                            <td>110 m²</td>
                            <td class="fw-bold">380 OMR</td>
                            <td class="text-end pe-4"><button class="btn btn-sm btn-dark">Book Preview</button></td>
                        </tr>
                    </tbody>
                </table>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card border-0 shadow-sm p-4 sticky-top" style="top: 20px;">
                <h5 class="fw-bold mb-4 text-center">Interested in this property?</h5>
                <form>
                    <div class="mb-3">
                        <input type="text" class="form-control" placeholder="Full Name">
                    </div>
                    <div class="mb-3">
                        <input type="tel" class="form-control" placeholder="Phone Number">
                    </div>
                    <div class="mb-3">
                        <select class="form-select">
                            <option selected disabled>Choose Your Preferred Unit</option>
                            <option>Apartment #102</option>
                            <option>Apartment #305</option>
                        </select>
                    </div>
                    <button class="btn btn-primary w-100 py-2 mb-3">Submit Inquiry</button>
                    <a href="https://wa.me/96812345678" class="btn btn-success w-100 py-2">
                        <i class="fab fa-whatsapp ms-2"></i> Contact via WhatsApp
                    </a>
                </form>
            </div>
        </div>
    </div>
</div>