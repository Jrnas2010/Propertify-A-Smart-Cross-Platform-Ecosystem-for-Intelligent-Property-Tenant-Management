@model IEnumerable<Propertify.Web.Models.Property>
@{
    ViewData["Title"] = "Buildings";
}

<link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />

<div class="container-fluid py-4 bg-light min-vh-100" style="max-width: 100%;">
    <!-- Header Section -->
    <div class="d-flex justify-content-between align-items-center mb-2 flex-wrap gap-3">
        <div>
            <h4 class="fw-bold text-dark mb-0">Buildings</h4>
            <p class="text-muted small">Manage your property portfolio</p>
        </div>
        <button class="btn btn-primary rounded-3 px-4 py-2" style="background-color: #2c3e50; border: none;"
                data-bs-toggle="modal" data-bs-target="#addPropertyModal">
            <i class="fas fa-plus me-2"></i> Add Building
        </button>
    </div>

    <!-- Search Bar -->
    <div class="row mb-4">
        <div class="col-12 col-md-6 col-lg-5">
            <form method="get" asp-action="Index">
                <div class="input-group bg-white shadow-sm rounded-3">
                    <span class="input-group-text bg-white border-0">
                        <i class="fas fa-search text-muted"></i>
                    </span>
                    <input type="text" name="searchTerm" value="@ViewBag.SearchTerm"
                           class="form-control border-0 py-2" placeholder="Search by name or location...">
                    @if (!string.IsNullOrEmpty(ViewBag.SearchTerm as string))
                    {
                        <a asp-action="Index" class="btn btn-outline-secondary border-0" title="Clear search">
                            <i class="fas fa-times"></i>
                        </a>
                    }
                </div>
            </form>
        </div>
    </div>

    @if (!Model.Any())
    {
        <div class="text-center py-5 text-muted">
            <i class="fas fa-building fa-3x mb-3 opacity-25 d-block"></i>
            <p>No buildings found.
                <a href="#" data-bs-toggle="modal" data-bs-target="#addPropertyModal">Add your first building.</a>
            </p>
        </div>
    }

    <!-- Map -->
    <div class="mt-4 w-100">
        <h2 class="mb-4">خريطة عقارات ولاية السيب</h2>
        <div id="map" style="height: 500px; width: 100%; overflow: hidden;" class="rounded-4 shadow-sm mb-4"></div>
    </div>

    @foreach (var property in Model)
    {
        <div class="modal fade" id="propModal-@property.Id" tabindex="-1" aria-hidden="true">
            <div class="modal-dialog modal-lg modal-dialog-centered">
                <div class="modal-content border-0 rounded-4 shadow-lg">
                    <div class="modal-header border-0 pb-0">
                        <h5 class="modal-title fw-bold">تفاصيل عقار: @property.Name</h5>
                        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                    </div>
                    <div class="modal-body">
                        <div class="row">
                            <div class="col-md-5">
                                <img src="@(string.IsNullOrEmpty(property.ImageUrl) ? "/images/default-building.jpg" : property.ImageUrl)"
                                     class="img-fluid rounded-3 shadow-sm mb-3">
                                <p class="text-muted small"><i class="fas fa-map-marker-alt me-2"></i>@property.Location</p>
                            </div>
                            <div class="col-md-7">
                                <h6 class="fw-bold mb-3">الوحدات الشاغرة المتوفرة:</h6>
                                <div class="list-group">
                                    @foreach (var unit in property.Units.Where(u => u.Status == "Vacant"))
                                    {
                                        <div class="list-group-item d-flex justify-content-between align-items-center border-light">
                                            <span>وحدة رقم: @unit.UnitNumber (طابق @unit.FloorNumber)</span>
                                            <a href="/Booking/Request/@unit.Id" class="btn btn-sm btn-success">حجز</a>
                                        </div>
                                    }
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    }

    <!-- Properties Grid -->
    <div class="row g-4">
        @foreach (var item in Model)
        {
            <div class="col-xl-4 col-lg-6 col-md-6 col-sm-12 mb-3">
                <div class="card border-0 shadow-sm rounded-4 overflow-hidden h-100">
                    <!-- Property Image with Overlay -->
                    <div class="position-relative" style="height: 200px;">
                        <img src="@(string.IsNullOrEmpty(item.ImageUrl) ? "/images/default-building.jpg" : item.ImageUrl)"
                             class="w-100 h-100 object-fit-cover" alt="@item.Name">

                        <div class="position-absolute bottom-0 start-0 w-100 p-3"
                             style="background: linear-gradient(transparent, rgba(0,0,0,0.8));">
                            <h5 class="text-white fw-bold mb-1">@item.Name</h5>
                            <p class="text-white-50 small mb-0">
                                <i class="fas fa-map-marker-alt me-1"></i> @item.Location
                            </p>
                        </div>
                        <span class="badge position-absolute top-0 end-0 m-3 bg-white bg-opacity-25 text-white fw-normal rounded-pill">
                            @item.Type
                        </span>
                    </div>

                    <!-- Property Stats -->
                    <div class="card-body p-3">
                        <div class="row text-center mb-3">
                            <div class="col-6 border-end">
                                <div class="d-flex align-items-center justify-content-center">
                                    <div class="bg-primary-subtle p-2 rounded-3 text-primary me-2">
                                        <i class="fas fa-door-open small"></i>
                                    </div>
                                    <div class="text-start">
                                        <div class="text-muted x-small">Units</div>
                                        <div class="fw-bold">@item.Units.Count</div>
                                    </div>
                                </div>
                            </div>
                            <div class="col-6">
                                <div class="d-flex align-items-center justify-content-center">
                                    <div class="bg-warning-subtle p-2 rounded-3 text-warning me-2">
                                        <i class="fas fa-home small"></i>
                                    </div>
                                    <div class="text-start">
                                        <div class="text-muted x-small">Vacant Units</div>
                                        <div class="fw-bold">@item.Units.Count(u => !u.IsOccupied)</div>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <!-- Action Buttons -->
                        <div class="d-flex gap-2">
                            <a asp-action="Details" asp-route-id="@item.Id"
                               class="btn btn-outline-dark flex-grow-1 rounded-3 py-2 fw-medium border-light-subtle">
                                View Details
                            </a>
                            <a asp-action="Edit" asp-route-id="@item.Id"
                               class="btn btn-outline-secondary rounded-3 py-2 px-3" title="Edit">
                                <i class="fas fa-edit"></i>
                            </a>
                            <form asp-action="Delete" asp-route-id="@item.Id" method="post"
                                  onsubmit="return confirm('Delete this building and all its units?')">
                                @Html.AntiForgeryToken()
                                <button type="submit" class="btn btn-outline-danger rounded-3 py-2 px-3" title="Delete">
                                    <i class="fas fa-trash"></i>
                                </button>
                            </form>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
</div>

<!-- Add Property Modal -->
<div class="modal fade" id="addPropertyModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-xl modal-dialog-centered shadow-lg" style="max-width: 95vw; max-height: 95vh; overflow-y: auto;">
        <div class="modal-content border-0">
            <form asp-action="Create" asp-controller="Property" method="post" enctype="multipart/form-data">
                <div class="modal-header bg-primary text-white p-4">
                    <h5 class="modal-title fw-bold"><i class="fas fa-building ms-2"></i> Add New Property</h5>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body p-4 bg-light text-end" dir="rtl">
                    <div class="card border-0 shadow-sm p-4 mb-4 rounded-4">
                        <h6 class="fw-bold text-primary mb-3 border-bottom pb-2">Property Details</h6>
                        <div class="row g-3">
                            <div class="col-md-4">
                                <label class="form-label small fw-bold">Property Name</label>
                                <input type="text" name="Name" class="form-control rounded-3 shadow-none" placeholder="Building Name" required>
                            </div>
                            <div class="col-md-4">
                                <label class="form-label small fw-bold">Property Type</label>
                                <select name="Type" class="form-select rounded-3 shadow-none">
                                    <option value="سكني">Residential</option>
                                    <option value="تجاري">Commercial</option>
                                    <option value="سكني تجاري">Residential & Commercial</option>
                                </select>
                            </div>
                            <div class="col-md-4">
                                <label class="form-label small fw-bold">Total Units</label>
                                <input type="number" name="TotalUnits" class="form-control rounded-3 shadow-none">
                            </div>
                            <div class="col-md-6">
                                <label class="form-label small fw-bold">Location</label>
                                <input type="text" name="Location" class="form-control rounded-3 shadow-none" placeholder="e.g. Muscat, Seeb">
                            </div>
                            <div class="col-md-6">
                                <label class="form-label small fw-bold text-primary">
                                    <i class="fas fa-image ms-1"></i> Property Image
                                </label>
                                <input type="file" name="ImageFile" class="form-control rounded-3 shadow-none"
                                       accept="image/*" onchange="previewPropertyImage(this)">
                                <div id="propertyImagePreview" class="mt-3 d-none">
                                    <img id="targetImage" src="#" class="img-thumbnail rounded-3 shadow-sm" style="max-height: 120px;">
                                    <small class="text-muted d-block mt-1">Image Preview</small>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="card border-0 shadow-sm p-4 rounded-4">
                        <div class="d-flex justify-content-between align-items-center mb-3 border-bottom pb-2">
                            <h6 class="fw-bold text-primary mb-0">Unit Details</h6>
                            <button type="button" class="btn btn-sm btn-success rounded-pill px-3" onclick="addUnitType()">
                                <i class="fas fa-plus ms-1"></i> Add Another Unit
                            </button>
                        </div>
                        <div id="unitTypesContainer">
                            <div class="unit-type-row bg-white border rounded-4 p-3 mb-3 shadow-sm position-relative">
                                <div class="row g-3">
                                    <div class="col-md-2"><label class="small fw-bold">Unit Number</label><input type="text" name="Units[0].UnitNumber" class="form-control form-control-sm rounded-2 shadow-none"></div>
                                    <div class="col-md-2"><label class="small fw-bold">Area (m²)</label><input type="number" name="Units[0].Area" class="form-control form-control-sm rounded-2 shadow-none"></div>
                                    <div class="col-md-4"><label class="small fw-bold text-primary">Electricity Meter</label><input type="text" name="Units[0].ElectricityMeter" class="form-control form-control-sm rounded-2 shadow-none"></div>
                                    <div class="col-md-4"><label class="small fw-bold text-info">Water Meter</label><input type="text" name="Units[0].WaterMeter" class="form-control form-control-sm rounded-2 shadow-none"></div>
                                    <div class="col-md-6"><label class="small fw-bold text-success">Unit Images</label><input type="file" name="Units[0].UnitImageFiles" class="form-control form-control-sm" multiple></div>
                                    <div class="col-md-6"><label class="small fw-bold text-danger">Preview Video</label><input type="file" name="Units[0].VideoFile" class="form-control form-control-sm" accept="video/*"></div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="modal-footer bg-light">
                    <button type="button" class="btn btn-secondary rounded-pill px-4" data-bs-dismiss="modal">Close</button>
                    <button type="submit" class="btn btn-primary rounded-pill px-4">Save Property</button>
                </div>
            </form>
        </div>
    </div>
</div>

<style>
    .object-fit-cover { object-fit: cover; }
    .x-small { font-size: 0.7rem; }
    .card:hover { transform: translateY(-5px); transition: 0.3s; }
</style>

@section Scripts {
    <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
    <script>
        var map = L.map('map').setView([23.67, 58.18], 12);
        L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
            attribution: '© OpenStreetMap contributors'
        }).addTo(map);

        var properties = @Html.Raw(Json.Serialize(Model.Select(p => new { p.Id, p.Name, p.Latitude, p.Longitude })));

        properties.forEach(function(prop) {
            if (prop.latitude) {
                var marker = L.marker([prop.latitude, prop.longitude]).addTo(map);

                marker.on('click', function() {
                    var modalEl = document.querySelector('#propModal-' + prop.id);
                    new bootstrap.Modal(modalEl).show();
                });

                marker.bindTooltip(prop.name, { permanent: false, direction: 'top' });
            }
        });
    </script>
    <script>
        let unitIndex = 1;


        function previewPropertyImage(input) {
            const previewDiv = document.getElementById('propertyImagePreview');
            const targetImg = document.getElementById('targetImage');
            if (input.files && input.files[0]) {
                const reader = new FileReader();
                reader.onload = function (e) {
                    targetImg.src = e.target.result;
                    previewDiv.classList.remove('d-none');
                }
                reader.readAsDataURL(input.files[0]);
            }
        }

        function addUnitType() {
            const container = document.getElementById('unitTypesContainer');
            const newRow = document.createElement('div');
            newRow.className = 'unit-type-row bg-white border rounded-4 p-3 mb-3 shadow-sm position-relative';
            newRow.innerHTML = `
                <button type="button" class="btn-close position-absolute top-0 start-0 m-3"
                        onclick="this.parentElement.remove()" style="font-size: 0.7rem;"></button>
                <div class="row g-3 mt-1">
                    <div class="col-md-2"><label class="small fw-bold">Unit Number</label><input type="text" name="Units[${unitIndex}].UnitNumber" class="form-control form-control-sm rounded-2 shadow-none"></div>
                    <div class="col-md-2"><label class="small fw-bold">Area (m²)</label><input type="number" name="Units[${unitIndex}].Area" class="form-control form-control-sm rounded-2 shadow-none"></div>
                    <div class="col-md-4"><label class="small fw-bold text-primary">Electricity Meter</label><input type="text" name="Units[${unitIndex}].ElectricityMeter" class="form-control form-control-sm rounded-2 shadow-none"></div>
                    <div class="col-md-4"><label class="small fw-bold text-info">Water Meter</label><input type="text" name="Units[${unitIndex}].WaterMeter" class="form-control form-control-sm rounded-2 shadow-none"></div>
                    <div class="col-md-6"><label class="small fw-bold text-success">Unit Images</label><input type="file" name="Units[${unitIndex}].UnitImageFiles" class="form-control form-control-sm" multiple></div>
                    <div class="col-md-6"><label class="small fw-bold text-danger">Preview Video</label><input type="file" name="Units[${unitIndex}].VideoFile" class="form-control form-control-sm" accept="video/*"></div>
                </div>`;
            container.appendChild(newRow);
            unitIndex++;
        }
    </script>
}
