@{
    ViewData["Title"] = "System Settings | Propertify";
    var sd = ViewBag.SettingsDict as Dictionary<string, string> ?? new Dictionary<string, string>();
    string Get(string key, string def) => sd.TryGetValue(key, out var v) ? v : def;
    var activeTab = Context.Request.Query["tab"].FirstOrDefault() ?? "appearance";
}

<div class="container-fluid py-4" style="max-width:100%;">
    <div class="mb-4">
        <h4 class="fw-bold mb-0" style="color:#0f172a;">System Settings</h4>
        <p class="mb-0 small" style="color:#94a3b8;">Manage appearance, permissions, and system configuration</p>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show border-0 shadow-sm rounded-3 mb-4" role="alert">
            <i class="fas fa-check-circle me-2"></i> @TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show border-0 shadow-sm rounded-3 mb-4" role="alert">
            <i class="fas fa-exclamation-circle me-2"></i> @TempData["Error"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <div class="row g-4">
        <!-- ── LEFT NAV ── -->
        <div class="col-md-3">
            <div class="card border-0 shadow-sm rounded-4 p-3 h-100">
                <div class="nav flex-column nav-pills gap-1" id="settingsTab" role="tablist" aria-orientation="vertical">
                    <button class="nav-link text-start @(activeTab == "appearance" ? "active" : "")"
                            id="tab-appearance" data-bs-toggle="pill" data-bs-target="#panel-appearance" type="button">
                        <i class="fas fa-palette me-2"></i> Appearance
                    </button>
                    <button class="nav-link text-start @(activeTab == "permissions" ? "active" : "")"
                            id="tab-permissions" data-bs-toggle="pill" data-bs-target="#panel-permissions" type="button">
                        <i class="fas fa-user-shield me-2"></i> User Permissions
                    </button>
                    <button class="nav-link text-start @(activeTab == "general" ? "active" : "")"
                            id="tab-general" data-bs-toggle="pill" data-bs-target="#panel-general" type="button">
                        <i class="fas fa-cog me-2"></i> General Settings
                    </button>
                    <button class="nav-link text-start text-danger @(activeTab == "security" ? "active" : "")"
                            id="tab-security" data-bs-toggle="pill" data-bs-target="#panel-security" type="button">
                        <i class="fas fa-lock me-2"></i> Security &amp; Password
                    </button>
                </div>
            </div>
        </div>

        <!-- ── RIGHT PANELS ── -->
        <div class="col-md-9">
            <div class="tab-content">

                <!-- ━━━━━━━━━━━━━━━━  APPEARANCE  ━━━━━━━━━━━━━━━━ -->
                <div class="tab-pane fade @(activeTab == "appearance" ? "show active" : "")" id="panel-appearance" role="tabpanel">
                    <form asp-action="SaveAppearance" method="post">
                        @Html.AntiForgeryToken()
                        <div class="card border-0 shadow-sm rounded-4 p-4 mb-4">
                            <h5 class="fw-bold mb-1">Appearance Customization</h5>
                            <p class="text-muted small mb-4">Customize the look and feel of the admin dashboard.</p>

                            <!-- Color section -->
                            <h6 class="fw-semibold text-uppercase mb-3" style="font-size:0.72rem; letter-spacing:.08em; color:#94a3b8;">
                                <i class="fas fa-circle-half-stroke me-2"></i>BRAND COLORS
                            </h6>
                            <div class="row g-3 mb-4">
                                <!-- Sidebar Color -->
                                <div class="col-md-4">
                                    <label class="form-label small fw-bold">Sidebar Color</label>
                                    <div class="d-flex align-items-center gap-3 p-2 rounded-3 border" style="background:#f8fafc;">
                                        <input type="color" name="sidebarColor" id="sidebarColorPicker"
                                               value="@Get("SidebarColor","#0f172a")"
                                               class="border-0 rounded-2 flex-shrink-0"
                                               style="width:44px;height:44px;padding:2px;cursor:pointer;background:transparent;"
                                               oninput="updatePreview()">
                                        <div>
                                            <div class="small fw-bold">Sidebar</div>
                                            <code class="small text-muted" id="sidebarColorHex">@Get("SidebarColor","#0f172a")</code>
                                        </div>
                                    </div>
                                </div>
                                <!-- Primary Color -->
                                <div class="col-md-4">
                                    <label class="form-label small fw-bold">Primary Color</label>
                                    <div class="d-flex align-items-center gap-3 p-2 rounded-3 border" style="background:#f8fafc;">
                                        <input type="color" name="primaryColor" id="primaryColorPicker"
                                               value="@Get("PrimaryColor","#1e3a5f")"
                                               class="border-0 rounded-2 flex-shrink-0"
                                               style="width:44px;height:44px;padding:2px;cursor:pointer;background:transparent;"
                                               oninput="updatePreview()">
                                        <div>
                                            <div class="small fw-bold">Primary</div>
                                            <code class="small text-muted" id="primaryColorHex">@Get("PrimaryColor","#1e3a5f")</code>
                                        </div>
                                    </div>
                                </div>
                                <!-- Accent Color -->
                                <div class="col-md-4">
                                    <label class="form-label small fw-bold">Accent / Button Color</label>
                                    <div class="d-flex align-items-center gap-3 p-2 rounded-3 border" style="background:#f8fafc;">
                                        <input type="color" name="accentColor" id="accentColorPicker"
                                               value="@Get("AccentColor","#3b82f6")"
                                               class="border-0 rounded-2 flex-shrink-0"
                                               style="width:44px;height:44px;padding:2px;cursor:pointer;background:transparent;"
                                               oninput="updatePreview()">
                                        <div>
                                            <div class="small fw-bold">Accent</div>
                                            <code class="small text-muted" id="accentColorHex">@Get("AccentColor","#3b82f6")</code>
                                        </div>
                                    </div>
                                </div>
                            </div>

                            <!-- Font Family -->
                            <h6 class="fw-semibold text-uppercase mb-3" style="font-size:0.72rem; letter-spacing:.08em; color:#94a3b8;">
                                <i class="fas fa-font me-2"></i>TYPOGRAPHY
                            </h6>
                            <div class="row g-3 mb-4">
                                <div class="col-md-6">
                                    <label class="form-label small fw-bold">Font Family</label>
                                    <select name="fontFamily" id="fontFamilySelect" class="form-select bg-light border-0 rounded-3"
                                            onchange="updateFontPreview()">
                                        @{
                                            var fonts = new[] { "Inter", "Plus Jakarta Sans", "Roboto", "Poppins", "Cairo" };
                                            var currentFont = Get("FontFamily", "Inter");
                                        }
                                        @foreach (var f in fonts)
                                        {
                                            if (currentFont == f)
                                            {
                                                <option value="@f" selected="selected">@f</option>
                                            }
                                            else
                                            {
                                                <option value="@f">@f</option>
                                            }
                                        }
                                    </select>
                                </div>
                                <div class="col-md-6 d-flex align-items-end">
                                    <div id="fontPreviewBox" class="rounded-3 px-4 py-3 w-100 text-center"
                                         style="background:#f1f5f9; font-size:1rem;">
                                        The quick brown fox jumps over the lazy dog.
                                    </div>
                                </div>
                            </div>

                            <!-- Live Preview -->
                            <h6 class="fw-semibold text-uppercase mb-3" style="font-size:0.72rem; letter-spacing:.08em; color:#94a3b8;">
                                <i class="fas fa-eye me-2"></i>LIVE PREVIEW
                            </h6>
                            <div class="rounded-4 overflow-hidden border" style="height:180px; display:flex;">
                                <!-- Mini sidebar -->
                                <div id="prevSidebar" class="d-flex flex-column p-3 gap-2 flex-shrink-0"
                                     style="width:130px; background:#0f172a;">
                                    <div class="rounded-2 d-flex align-items-center gap-2 px-2 py-1" style="background:rgba(255,255,255,0.1);">
                                        <div id="prevAccentDot" class="rounded" style="width:8px;height:8px;background:#3b82f6;flex-shrink:0;"></div>
                                        <span class="text-white" style="font-size:0.65rem;">Dashboard</span>
                                    </div>
                                    <div class="rounded-2 d-flex align-items-center gap-2 px-2 py-1">
                                        <div class="rounded" style="width:8px;height:8px;background:rgba(255,255,255,0.2);flex-shrink:0;"></div>
                                        <span style="font-size:0.65rem; color:rgba(255,255,255,0.45);">Tenants</span>
                                    </div>
                                    <div class="rounded-2 d-flex align-items-center gap-2 px-2 py-1">
                                        <div class="rounded" style="width:8px;height:8px;background:rgba(255,255,255,0.2);flex-shrink:0;"></div>
                                        <span style="font-size:0.65rem; color:rgba(255,255,255,0.45);">Contracts</span>
                                    </div>
                                </div>
                                <!-- Mini content -->
                                <div class="flex-grow-1 p-3" style="background:#f8fafc;">
                                    <div id="prevPrimaryBar" class="rounded-2 mb-3 px-3 py-2 d-flex align-items-center gap-2"
                                         style="background:#1e3a5f;">
                                        <span class="text-white fw-bold" style="font-size:0.7rem;">PROPERTIFY</span>
                                        <span class="ms-auto badge text-white rounded-pill px-2"
                                              id="prevAccentBadge" style="background:#3b82f6; font-size:0.55rem;">LIVE</span>
                                    </div>
                                    <div class="d-flex gap-2">
                                        <div class="rounded-3 p-2 flex-grow-1" style="background:#fff; box-shadow:0 1px 3px rgba(0,0,0,.06);">
                                            <div id="prevAccentBtn" class="rounded-pill text-center text-white py-1"
                                                 style="background:#3b82f6; font-size:0.6rem; font-weight:700;">+ ADD USER</div>
                                        </div>
                                        <div class="rounded-3 p-2 flex-grow-1" style="background:#fff; box-shadow:0 1px 3px rgba(0,0,0,.06);">
                                            <div class="rounded-2" style="height:14px; background:#f1f5f9; margin-bottom:4px;"></div>
                                            <div class="rounded-2" style="height:8px; background:#f1f5f9; width:60%;"></div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <!-- Reset + Save -->
                        <div class="d-flex gap-2 justify-content-end">
                            <button type="button" class="btn btn-light rounded-pill px-4"
                                    onclick="resetToDefaults()">
                                <i class="fas fa-rotate-left me-1"></i> Reset to Defaults
                            </button>
                            <button type="submit" class="btn btn-primary rounded-pill px-5">
                                <i class="fas fa-save me-1"></i> Save Appearance
                            </button>
                        </div>
                    </form>
                </div>

                <!-- ━━━━━━━━━━━━━━━━  PERMISSIONS  ━━━━━━━━━━━━━━━━ -->
                <div class="tab-pane fade @(activeTab == "permissions" ? "show active" : "")" id="panel-permissions" role="tabpanel">
                    <div class="card border-0 shadow-sm rounded-4 p-4">
                        <h5 class="fw-bold mb-1">User Permissions Management</h5>
                        <p class="text-muted small mb-4">Configure which actions each user can perform in the system.</p>
                        <div class="table-responsive">
                            <table class="table table-hover align-middle">
                                <thead class="table-light">
                                    <tr>
                                        <th>Tenant</th>
                                        <th>Property</th>
                                        <th class="text-center">Edit Profile</th>
                                        <th class="text-center">Submit Maintenance</th>
                                        <th class="text-center">Upload Payments</th>
                                        <th>Actions</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <tr>
                                        <td>
                                            <span class="fw-bold d-block">سالم الهنائي</span>
                                            <small class="text-muted">ID: 10293</small>
                                        </td>
                                        <td>بناية المها</td>
                                        <td class="text-center"><div class="form-check form-switch d-inline-block"><input class="form-check-input" type="checkbox" checked></div></td>
                                        <td class="text-center"><div class="form-check form-switch d-inline-block"><input class="form-check-input" type="checkbox" checked></div></td>
                                        <td class="text-center"><div class="form-check form-switch d-inline-block"><input class="form-check-input" type="checkbox" checked></div></td>
                                        <td><button class="btn btn-sm btn-outline-primary rounded-pill px-3">Save</button></td>
                                    </tr>
                                    <tr>
                                        <td>
                                            <span class="fw-bold d-block">محمد البلوشي</span>
                                            <small class="text-muted">ID: 10294</small>
                                        </td>
                                        <td>برج النور</td>
                                        <td class="text-center"><div class="form-check form-switch d-inline-block"><input class="form-check-input" type="checkbox"></div></td>
                                        <td class="text-center"><div class="form-check form-switch d-inline-block"><input class="form-check-input" type="checkbox" checked></div></td>
                                        <td class="text-center"><div class="form-check form-switch d-inline-block"><input class="form-check-input" type="checkbox"></div></td>
                                        <td><button class="btn btn-sm btn-outline-primary rounded-pill px-3">Save</button></td>
                                    </tr>
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>

                <!-- ━━━━━━━━━━━━━━━━  GENERAL  ━━━━━━━━━━━━━━━━ -->
                <div class="tab-pane fade @(activeTab == "general" ? "show active" : "")" id="panel-general" role="tabpanel">
                    <form asp-action="UpdateSystemSettings" method="post" enctype="multipart/form-data">
                        @Html.AntiForgeryToken()
                        <div class="card border-0 shadow-sm rounded-4 p-4 mb-4">
                            <h5 class="fw-bold mb-1">General Settings</h5>
                            <p class="text-muted small mb-4">Configure the system name and branding.</p>

                            <div class="row g-3">
                                <div class="col-md-6">
                                    <label class="form-label small fw-bold">Site Name</label>
                                    <input type="text" name="siteName" class="form-control bg-light border-0 rounded-3"
                                           value="@Get("SiteName","Propertify")" placeholder="Propertify">
                                </div>
                                <div class="col-md-6">
                                    <label class="form-label small fw-bold">Logo Image</label>
                                    <input type="file" name="LogoFile" class="form-control bg-light border-0 rounded-3"
                                           accept="image/jpeg,image/png,image/webp,image/svg+xml">
                                    <div class="form-text">JPEG, PNG, WebP, or SVG — max 2 MB</div>
                                </div>
                            </div>
                        </div>
                        <div class="d-flex justify-content-end">
                            <button type="submit" class="btn btn-primary rounded-pill px-5">
                                <i class="fas fa-save me-1"></i> Save Settings
                            </button>
                        </div>
                    </form>
                </div>

                <!-- ━━━━━━━━━━━━━━━━  SECURITY  ━━━━━━━━━━━━━━━━ -->
                <div class="tab-pane fade @(activeTab == "security" ? "show active" : "")" id="panel-security" role="tabpanel">
                    <div class="card border-0 shadow-sm rounded-4 p-4">
                        <h5 class="fw-bold mb-1">Security &amp; Password</h5>
                        <p class="text-muted small mb-4">Manage account security settings.</p>
                        <div class="text-center py-5 text-muted">
                            <i class="fas fa-lock fa-3x mb-3 opacity-25 d-block"></i>
                            <p>Security settings will be available in a future release.</p>
                        </div>
                    </div>
                </div>

            </div>
        </div>
    </div>
</div>

<style>
    .nav-pills .nav-link { color: #1e3a5f; border-radius: 0.6rem; padding: 0.6rem 0.9rem; font-size: 0.875rem; }
    .nav-pills .nav-link.active { background-color: var(--primary-color, #1e3a5f); color: #fff; }
    .form-switch .form-check-input { width: 2.6em; height: 1.4em; cursor: pointer; }
    input[type=color] { appearance: none; -webkit-appearance: none; border: none; }
    input[type=color]::-webkit-color-swatch-wrapper { padding: 0; }
    input[type=color]::-webkit-color-swatch { border: none; border-radius: 6px; }
</style>

<script>
    function updatePreview() {
        const sidebar = document.getElementById('sidebarColorPicker').value;
        const primary = document.getElementById('primaryColorPicker').value;
        const accent  = document.getElementById('accentColorPicker').value;

        document.getElementById('sidebarColorHex').textContent = sidebar;
        document.getElementById('primaryColorHex').textContent = primary;
        document.getElementById('accentColorHex').textContent  = accent;

        document.getElementById('prevSidebar').style.background    = sidebar;
        document.getElementById('prevPrimaryBar').style.background = primary;
        document.getElementById('prevAccentDot').style.background  = accent;
        document.getElementById('prevAccentBadge').style.background = accent;
        document.getElementById('prevAccentBtn').style.background  = accent;
    }

    function updateFontPreview() {
        const font = document.getElementById('fontFamilySelect').value;
        const googleBase = 'https://fonts.googleapis.com/css2?family=';
        const links = {
            'Inter':              googleBase + 'Inter:wght@400;500;600;700&display=swap',
            'Plus Jakarta Sans':  googleBase + 'Plus+Jakarta+Sans:wght@400;500;600;700&display=swap',
            'Roboto':             googleBase + 'Roboto:wght@400;500;700&display=swap',
            'Poppins':            googleBase + 'Poppins:wght@400;500;600;700&display=swap',
            'Cairo':              googleBase + 'Cairo:wght@400;600;700&display=swap'
        };
        const box = document.getElementById('fontPreviewBox');
        box.style.fontFamily = `'${font}', sans-serif`;

        let existing = document.getElementById('previewFontLink');
        if (!existing) {
            existing = document.createElement('link');
            existing.id  = 'previewFontLink';
            existing.rel = 'stylesheet';
            document.head.appendChild(existing);
        }
        existing.href = links[font] || '';
    }

    function resetToDefaults() {
        document.getElementById('sidebarColorPicker').value = '#0f172a';
        document.getElementById('primaryColorPicker').value = '#1e3a5f';
        document.getElementById('accentColorPicker').value  = '#3b82f6';
        document.getElementById('fontFamilySelect').value   = 'Inter';
        updatePreview();
        updateFontPreview();
    }

    // Init
    updatePreview();
    updateFontPreview();
</script>
