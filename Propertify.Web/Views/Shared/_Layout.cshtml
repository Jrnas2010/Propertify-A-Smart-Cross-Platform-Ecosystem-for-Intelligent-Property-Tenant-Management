@using System.Threading
@using Microsoft.AspNetCore.Mvc.Localization
@inject IViewLocalizer Localizer
@{
    var isRTL = Thread.CurrentThread.CurrentUICulture.Name.StartsWith("ar");
    var currentController = ViewContext.RouteData.Values["controller"]?.ToString();
    var userName = User.Identity?.Name ?? "Admin";
}

<!DOCTYPE html>
<html lang="@(isRTL ? "ar" : "en")" dir="@(isRTL ? "rtl" : "ltr")">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Propertify</title>

    @if (isRTL)
    {
        <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.rtl.min.css">
    }
    else
    {
        <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css">
    }
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />

    <style>
        :root { --sidebar-width: 260px; }

        .main-sidebar {
            width: var(--sidebar-width);
            min-height: 100vh;
            position: fixed;
            top: 0;
            @(isRTL ? "right: 0;" : "left: 0;")
            background-color: #34495e;
            display: flex;
            flex-direction: column;
            z-index: 1000;
            overflow-y: auto;
        }

        #page-content-wrapper {
            @(isRTL ? "margin-right: var(--sidebar-width);" : "margin-left: var(--sidebar-width);")
            min-height: 100vh;
            transition: margin 0.3s ease;
        }

        .sidebar-nav-link {
            color: rgba(255,255,255,0.6);
            padding: 0.75rem 1rem;
            border-radius: 0.5rem;
            display: flex;
            align-items: center;
            text-decoration: none;
            transition: all 0.2s ease;
            font-size: 0.9rem;
        }

        .sidebar-nav-link:hover {
            color: #fff;
            background-color: rgba(255,255,255,0.1);
        }

        .sidebar-nav-link.active {
            color: #fff;
            background-color: #4b6584;
            box-shadow: 0 2px 8px rgba(0,0,0,0.15);
        }

        .sidebar-nav-link i {
            width: 20px;
            text-align: center;
            @(isRTL ? "margin-left: 0.75rem;" : "margin-right: 0.75rem;")
        }

        /* Collapsed sidebar for small screens */
        @@media (max-width: 768px) {
            .main-sidebar { transform: translateX(@(isRTL ? "100%" : "-100%")); }
            .main-sidebar.open { transform: translateX(0); }
            #page-content-wrapper { @(isRTL ? "margin-right: 0;" : "margin-left: 0;") }
        }
    </style>
</head>
<body>

    <!-- Main Sidebar -->
    <aside class="main-sidebar" id="mainSidebar">

        <!-- Logo -->
        <div class="p-4 d-flex align-items-center">
            <div class="bg-white rounded-3 p-2 me-3 shadow-sm text-center" style="width: 45px; flex-shrink: 0;">
                <span class="fw-bold text-dark fs-5">P</span>
            </div>
            <div class="text-white">
                <h6 class="fw-bold mb-0">Propertify</h6>
                <small class="opacity-50" style="font-size: 0.7rem;">Property Manager</small>
            </div>
        </div>

        <!-- Navigation -->
        <nav class="px-3 flex-grow-1">
            <p class="text-white-50 small fw-bold px-3 mb-2" style="font-size: 0.65rem; letter-spacing: 0.08em; text-transform: uppercase;">
                Main Menu
            </p>
            <ul class="nav flex-column gap-1">
                <li class="nav-item">
                    <a asp-controller="Dashboard" asp-action="Index"
                       class="sidebar-nav-link @(currentController == "Dashboard" ? "active" : "")">
                        <i class="fas fa-th-large"></i> @Localizer["Dashboard"]
                    </a>
                </li>
                <li class="nav-item">
                    <a asp-controller="Property" asp-action="Index"
                       class="sidebar-nav-link @(currentController == "Property" ? "active" : "")">
                        <i class="fas fa-building"></i> @Localizer["Properties"]
                    </a>
                </li>
                <li class="nav-item">
                    <a asp-controller="Tenant" asp-action="Index"
                       class="sidebar-nav-link @(currentController == "Tenant" ? "active" : "")">
                        <i class="fas fa-users"></i> @Localizer["Tenants"]
                    </a>
                </li>
                <li class="nav-item">
                    <a asp-controller="Contract" asp-action="Index"
                       class="sidebar-nav-link @(currentController == "Contract" ? "active" : "")">
                        <i class="fas fa-file-contract"></i> @Localizer["Contracts"]
                    </a>
                </li>
                <li class="nav-item">
                    <a asp-controller="Maintenance" asp-action="Index"
                       class="sidebar-nav-link @(currentController == "Maintenance" ? "active" : "")">
                        <i class="fas fa-wrench"></i> @Localizer["Maintenance"]
                    </a>
                </li>
                <li class="nav-item">
                    <a asp-controller="Communication" asp-action="Index"
                       class="sidebar-nav-link @(currentController == "Communication" ? "active" : "")">
                        <i class="fas fa-envelope"></i> @Localizer["Communication"]
                    </a>
                </li>
            </ul>

            <hr class="my-3" style="border-color: rgba(255,255,255,0.1);">

            <p class="text-white-50 small fw-bold px-3 mb-2" style="font-size: 0.65rem; letter-spacing: 0.08em; text-transform: uppercase;">
                System
            </p>
            <ul class="nav flex-column gap-1">
                <li class="nav-item">
                    <a asp-controller="Settings" asp-action="Index"
                       class="sidebar-nav-link @(currentController == "Settings" ? "active" : "")">
                        <i class="fas fa-cog"></i> @Localizer["Settings"]
                    </a>
                </li>
            </ul>
        </nav>

        <!-- Sidebar Bottom: Language + Logout -->
        <div class="p-4 border-top" style="border-color: rgba(255,255,255,0.1) !important;">
            <!-- Language Switcher (functional links) -->
            <div class="d-flex gap-3 mb-3">
                <a asp-controller="Language" asp-action="ChangeLanguage"
                   asp-route-culture="en"
                   asp-route-returnUrl="@(Context.Request.Path + Context.Request.QueryString)"
                   class="text-decoration-none small @(!isRTL ? "text-white fw-bold" : "text-white-50")">
                    <i class="fas fa-globe me-1"></i> English
                </a>
                <a asp-controller="Language" asp-action="ChangeLanguage"
                   asp-route-culture="ar"
                   asp-route-returnUrl="@(Context.Request.Path + Context.Request.QueryString)"
                   class="text-decoration-none small @(isRTL ? "text-white fw-bold" : "text-white-50")">
                    عربي
                </a>
            </div>

            <!-- Logout (POST form for CSRF protection) -->
            <form asp-controller="Account" asp-action="Logout" method="post">
                @Html.AntiForgeryToken()
                <button type="submit"
                        class="btn p-0 border-0 bg-transparent text-white-50 small text-decoration-none w-100 text-start">
                    <i class="fas fa-sign-out-alt me-2"></i> @Localizer["Logout"]
                </button>
            </form>
        </div>
    </aside>

    <!-- Page Content -->
    <div id="page-content-wrapper">

        <!-- Top Navbar -->
        <nav class="navbar navbar-expand-lg navbar-light bg-white border-bottom shadow-sm sticky-top px-4">
            <button class="btn btn-link text-dark p-0 me-3" id="sidebarToggle">
                <i class="fas fa-bars fs-5"></i>
            </button>
            <span class="fw-semibold text-dark">@ViewData["Title"]</span>

            <div class="ms-auto d-flex align-items-center gap-3">
                <!-- User dropdown -->
                <div class="dropdown">
                    <a href="#" class="d-flex align-items-center text-decoration-none dropdown-toggle text-dark gap-2"
                       data-bs-toggle="dropdown">
                        <img src="https://ui-avatars.com/api/?name=@Uri.EscapeDataString(userName)&background=2c3e50&color=fff"
                             class="rounded-circle shadow-sm" width="36" height="36">
                        <span class="small fw-semibold d-none d-sm-block">@userName</span>
                    </a>
                    <ul class="dropdown-menu dropdown-menu-end shadow border-0 rounded-3 mt-2">
                        <li><span class="dropdown-item-text small text-muted">@Localizer["Owner"]</span></li>
                        <li><hr class="dropdown-divider"></li>
                        <li>
                            <form asp-controller="Account" asp-action="Logout" method="post">
                                @Html.AntiForgeryToken()
                                <button type="submit"
                                        class="dropdown-item py-2 text-danger border-0 bg-transparent w-100 text-start">
                                    <i class="fas fa-power-off me-2"></i> @Localizer["Logout"]
                                </button>
                            </form>
                        </li>
                    </ul>
                </div>
            </div>
        </nav>

        <!-- Main Content -->
        <div class="p-4">
            <main role="main">
                @RenderBody()
            </main>
        </div>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    <script>
        // Toggle sidebar on mobile
        document.getElementById('sidebarToggle').addEventListener('click', function () {
            document.getElementById('mainSidebar').classList.toggle('open');
        });
    </script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
