@model IEnumerable<Propertify.Web.Models.Supplier>
@{
    ViewData["Title"] = "Suppliers";
    var search       = ViewBag.Search as string ?? "";
    var serviceTypes = new[] { "Electricity", "Plumbing", "Elevator", "HVAC", "Cleaning", "Security", "Painting", "Carpentry", "Other" };
    var total        = Model.Count();
}

<style>
    /* ── Supplier page specific ─────────────────────────── */
    .sup-card {
        background: #ffffff;
        border-radius: 18px !important;
        border: none !important;
        box-shadow: 0 1px 6px rgba(0,0,0,0.07) !important;
        overflow: hidden;
        display: flex;
        flex-direction: column;
        transition: box-shadow 0.2s ease, transform 0.2s ease;
    }
    .sup-card:hover {
        box-shadow: 0 6px 20px rgba(0,0,0,0.1) !important;
        transform: translateY(-3px);
    }
    .sup-icon-box {
        width: 54px;
        height: 54px;
        border-radius: 14px;
        background: #eff6ff;
        display: flex;
        align-items: center;
        justify-content: center;
        flex-shrink: 0;
    }
    .sup-action-btn {
        background: transparent;
        border: none;
        padding: 4px 6px;
        color: #cbd5e1;
        cursor: pointer;
        transition: color 0.15s;
        line-height: 1;
    }
    .sup-action-btn:hover { color: #64748b; }
    .sup-service-badge {
        display: inline-flex;
        align-items: center;
        padding: 4px 14px;
        border-radius: 20px;
        border: 1px solid #e2e8f0;
        background: transparent;
        font-size: 0.68rem;
        font-weight: 700;
        letter-spacing: 0.08em;
        text-transform: uppercase;
        color: #374151;
    }
    .sup-contact-row {
        display: flex;
        align-items: center;
        gap: 10px;
        font-size: 0.875rem;
        color: #374151;
    }
    .sup-contact-row i {
        width: 16px;
        text-align: center;
        color: #9ca3af;
        font-size: 0.82rem;
        flex-shrink: 0;
    }
    .sup-status-strip {
        text-align: center;
        padding: 11px 0;
        font-size: 0.72rem;
        font-weight: 700;
        letter-spacing: 0.12em;
        text-transform: uppercase;
        margin-top: auto;
    }
    .sup-search-card {
        background: #fff;
        border-radius: 14px !important;
        border: 1px solid #f1f5f9 !important;
        box-shadow: 0 1px 4px rgba(0,0,0,0.05) !important;
        padding: 6px 4px;
    }
    .sup-search-card .form-control {
        background: transparent !important;
        border: none !important;
        box-shadow: none !important;
        font-size: 0.9rem;
        color: #374151;
        padding: 8px 4px;
    }
    .sup-search-card .form-control::placeholder { color: #94a3b8; }
    .sup-dl-btn {
        width: 44px;
        height: 44px;
        border: 1px solid #e2e8f0;
        background: #fff;
        border-radius: 12px;
        display: flex;
        align-items: center;
        justify-content: center;
        cursor: pointer;
        transition: border-color 0.15s, background 0.15s;
    }
    .sup-dl-btn:hover { border-color: #22c55e; background: #f0fdf4; }
</style>

<div class="container-fluid py-4" style="max-width:100%;">

    <!-- ── Header ──────────────────────────────────────────── -->
    <div class="d-flex justify-content-between align-items-end mb-4 flex-wrap gap-3">
        <div>
            <h2 class="fw-bold mb-1" style="font-size:2rem; color:#0f172a; line-height:1.1;">
                Suppliers &amp; Services
            </h2>
            <p class="mb-0" style="font-size:0.7rem; font-weight:700; letter-spacing:0.1em; text-transform:uppercase; color:#94a3b8;">
                @total Registered Supplier@(total != 1 ? "s" : "")
            </p>
        </div>
        <div class="d-flex align-items-center gap-2">
            <button class="sup-dl-btn" title="Export to Excel" onclick="exportSuppliers()">
                <i class="fas fa-download" style="color:#22c55e; font-size:0.9rem;"></i>
            </button>
            <button class="btn btn-primary rounded-3 px-4 fw-semibold"
                    style="height:44px; font-size:0.875rem;"
                    data-bs-toggle="modal" data-bs-target="#addSupplierModal">
                <i class="fas fa-plus me-2"></i>ADD SUPPLIER
            </button>
        </div>
    </div>

    <!-- ── Search ──────────────────────────────────────────── -->
    <div class="sup-search-card mb-4">
        <form method="get" asp-action="Index" class="d-flex align-items-center px-3">
            <i class="fas fa-search me-3" style="color:#94a3b8; font-size:0.9rem; flex-shrink:0;"></i>
            <input type="text" name="search" value="@search"
                   class="form-control flex-grow-1"
                   placeholder="Search for supplier or service..." />
            @if (!string.IsNullOrEmpty(search))
            {
                <a asp-action="Index" class="btn p-1 border-0 bg-transparent" style="color:#94a3b8; flex-shrink:0;">
                    <i class="fas fa-times" style="font-size:0.85rem;"></i>
                </a>
            }
        </form>
    </div>

    <!-- ── Empty State ─────────────────────────────────────── -->
    @if (!Model.Any())
    {
        <div class="text-center py-5">
            <div class="d-inline-flex align-items-center justify-content-center rounded-4 mb-4"
                 style="width:80px;height:80px;background:#eff6ff;">
                <i class="fas fa-truck" style="font-size:2rem;color:#3b82f6;opacity:0.5;"></i>
            </div>
            <h6 class="fw-semibold mb-1" style="color:#0f172a;">No suppliers yet</h6>
            <p class="mb-3" style="color:#94a3b8;font-size:0.875rem;">
                @(string.IsNullOrEmpty(search) ? "Add your first supplier to get started." : $"No results for \"{search}\".")
            </p>
            @if (!string.IsNullOrEmpty(search))
            {
                <a asp-action="Index" class="btn btn-outline-secondary rounded-pill px-4">Clear Search</a>
            }
            else
            {
                <button class="btn btn-primary rounded-pill px-4"
                        data-bs-toggle="modal" data-bs-target="#addSupplierModal">
                    <i class="fas fa-plus me-2"></i>Add Supplier
                </button>
            }
        </div>
    }
    else
    {
        <!-- ── Cards Grid ───────────────────────────────────── -->
        <div class="row g-4">
            @foreach (var s in Model)
            {
                bool isActive = s.Status?.Equals("Active", StringComparison.OrdinalIgnoreCase) == true;
                <div class="col-xl-4 col-lg-6">
                    <div class="sup-card h-100">

                        <!-- Card Body -->
                        <div class="p-4 flex-grow-1 d-flex flex-column">

                            <!-- Row 1: icon + actions -->
                            <div class="d-flex justify-content-between align-items-start mb-4">
                                <div class="sup-icon-box">
                                    <i class="fas fa-truck" style="color:#3b82f6; font-size:1.25rem;"></i>
                                </div>
                                <div class="d-flex align-items-center gap-1">
                                    <button class="sup-action-btn edit-btn"
                                            data-bs-toggle="modal" data-bs-target="#editSupplierModal"
                                            data-id="@s.Id"
                                            data-name="@s.Name"
                                            data-servicetype="@s.ServiceType"
                                            data-phone="@s.Phone"
                                            data-email="@s.Email"
                                            data-location="@s.Location"
                                            data-contactperson="@s.ContactPerson"
                                            data-status="@s.Status"
                                            title="Edit">
                                        <i class="fas fa-pen" style="font-size:0.88rem;"></i>
                                    </button>
                                    <button class="sup-action-btn delete-btn"
                                            data-bs-toggle="modal" data-bs-target="#deleteModal"
                                            data-id="@s.Id"
                                            data-name="@s.Name"
                                            title="Delete">
                                        <i class="fas fa-trash-can" style="font-size:0.88rem;"></i>
                                    </button>
                                </div>
                            </div>

                            <!-- Company name -->
                            <h5 class="fw-bold mb-2" style="font-size:1.05rem; color:#0f172a; line-height:1.3;">
                                @s.Name
                            </h5>

                            <!-- Service badge (outlined) -->
                            <div class="mb-4">
                                <span class="sup-service-badge">@(s.ServiceType ?? "—")</span>
                            </div>

                            <!-- Contact info -->
                            <div class="d-flex flex-column gap-3 mt-auto">
                                @if (!string.IsNullOrEmpty(s.Phone))
                                {
                                    <div class="sup-contact-row">
                                        <i class="fas fa-phone"></i>
                                        <span>@s.Phone</span>
                                    </div>
                                }
                                @if (!string.IsNullOrEmpty(s.Email))
                                {
                                    <div class="sup-contact-row">
                                        <i class="fas fa-envelope"></i>
                                        <span>@s.Email</span>
                                    </div>
                                }
                                @if (!string.IsNullOrEmpty(s.Location))
                                {
                                    <div class="sup-contact-row">
                                        <i class="fas fa-location-dot"></i>
                                        <span>@s.Location</span>
                                    </div>
                                }
                                @if (!string.IsNullOrEmpty(s.ContactPerson))
                                {
                                    <div class="sup-contact-row">
                                        <i class="fas fa-user"></i>
                                        <span>@s.ContactPerson</span>
                                    </div>
                                }
                            </div>
                        </div>

                        <!-- Status strip -->
                        <div class="sup-status-strip"
                             style="background:@(isActive ? "rgba(34,197,94,0.1)" : "rgba(100,116,139,0.08)");
                                    color:@(isActive ? "#16a34a" : "#64748b");">
                            @(s.Status?.ToUpper() ?? "UNKNOWN")
                        </div>

                    </div>
                </div>
            }
        </div>
    }
</div>

<!-- ══════════════════════════════════════════════════════════
     ADD SUPPLIER MODAL
══════════════════════════════════════════════════════════ -->
<div class="modal fade" id="addSupplierModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-lg">
        <div class="modal-content border-0 shadow-lg" style="border-radius:20px;">
            <form asp-action="Create" method="post">
                @Html.AntiForgeryToken()
                <div class="modal-header px-4 pt-4 pb-3" style="border-bottom:1px solid #f1f5f9;">
                    <div class="d-flex align-items-center gap-3">
                        <div class="sup-icon-box" style="width:42px;height:42px;border-radius:10px;">
                            <i class="fas fa-truck" style="color:#3b82f6;font-size:1rem;"></i>
                        </div>
                        <div>
                            <h5 class="fw-bold mb-0" style="color:#0f172a;">Add Supplier</h5>
                            <p class="mb-0" style="font-size:0.75rem;color:#94a3b8;">Fill in the supplier details below</p>
                        </div>
                    </div>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body px-4 py-4">
                    <div class="row g-3">
                        <div class="col-md-6">
                            <label class="form-label">Company Name <span class="text-danger">*</span></label>
                            <input type="text" name="Name" class="form-control" placeholder="e.g. Muscat Electric Co." required />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Service Type <span class="text-danger">*</span></label>
                            <select name="ServiceType" class="form-select" required>
                                <option value="">Select service...</option>
                                @foreach (var st in serviceTypes)
                                {
                                    <option value="@st">@st</option>
                                }
                            </select>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Phone</label>
                            <input type="text" name="Phone" class="form-control" placeholder="e.g. 24400000" />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Email</label>
                            <input type="email" name="Email" class="form-control" placeholder="e.g. info@example.com" />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Location</label>
                            <input type="text" name="Location" class="form-control" placeholder="e.g. Muscat, Oman" />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Contact Person</label>
                            <input type="text" name="ContactPerson" class="form-control" placeholder="e.g. Ahmed Al-Balushi" />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Status</label>
                            <select name="Status" class="form-select">
                                <option value="Active" selected>Active</option>
                                <option value="Inactive">Inactive</option>
                            </select>
                        </div>
                    </div>
                </div>
                <div class="modal-footer px-4 pb-4" style="border-top:1px solid #f1f5f9;">
                    <button type="button" class="btn btn-outline-secondary rounded-pill px-4" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-primary rounded-pill px-5 fw-semibold">
                        <i class="fas fa-plus me-2"></i>Save Supplier
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- ══════════════════════════════════════════════════════════
     EDIT SUPPLIER MODAL
══════════════════════════════════════════════════════════ -->
<div class="modal fade" id="editSupplierModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-lg">
        <div class="modal-content border-0 shadow-lg" style="border-radius:20px;">
            <form asp-action="Edit" method="post">
                @Html.AntiForgeryToken()
                <input type="hidden" name="Id" id="editId" />
                <div class="modal-header px-4 pt-4 pb-3" style="border-bottom:1px solid #f1f5f9;">
                    <div class="d-flex align-items-center gap-3">
                        <div class="sup-icon-box" style="width:42px;height:42px;border-radius:10px;">
                            <i class="fas fa-pen" style="color:#3b82f6;font-size:0.9rem;"></i>
                        </div>
                        <div>
                            <h5 class="fw-bold mb-0" style="color:#0f172a;">Edit Supplier</h5>
                            <p class="mb-0" style="font-size:0.75rem;color:#94a3b8;">Update the supplier information</p>
                        </div>
                    </div>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body px-4 py-4">
                    <div class="row g-3">
                        <div class="col-md-6">
                            <label class="form-label">Company Name <span class="text-danger">*</span></label>
                            <input type="text" name="Name" id="editName" class="form-control" required />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Service Type <span class="text-danger">*</span></label>
                            <select name="ServiceType" id="editServiceType" class="form-select" required>
                                @foreach (var st in serviceTypes)
                                {
                                    <option value="@st">@st</option>
                                }
                            </select>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Phone</label>
                            <input type="text" name="Phone" id="editPhone" class="form-control" />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Email</label>
                            <input type="email" name="Email" id="editEmail" class="form-control" />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Location</label>
                            <input type="text" name="Location" id="editLocation" class="form-control" />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Contact Person</label>
                            <input type="text" name="ContactPerson" id="editContactPerson" class="form-control" />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Status</label>
                            <select name="Status" id="editStatus" class="form-select">
                                <option value="Active">Active</option>
                                <option value="Inactive">Inactive</option>
                            </select>
                        </div>
                    </div>
                </div>
                <div class="modal-footer px-4 pb-4" style="border-top:1px solid #f1f5f9;">
                    <button type="button" class="btn btn-outline-secondary rounded-pill px-4" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-primary rounded-pill px-5 fw-semibold">
                        <i class="fas fa-check me-2"></i>Save Changes
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- ══════════════════════════════════════════════════════════
     DELETE MODAL
══════════════════════════════════════════════════════════ -->
<div class="modal fade" id="deleteModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered" style="max-width:420px;">
        <div class="modal-content border-0 shadow-lg" style="border-radius:20px; overflow:hidden;">
            <!-- Red top bar -->
            <div style="height:5px;background:linear-gradient(90deg,#ef4444,#f87171);"></div>
            <form asp-action="Delete" method="post">
                @Html.AntiForgeryToken()
                <input type="hidden" name="id" id="deleteId" />
                <div class="p-4 text-center">
                    <div class="d-inline-flex align-items-center justify-content-center rounded-4 mb-3"
                         style="width:62px;height:62px;background:#fef2f2;">
                        <i class="fas fa-trash-can" style="font-size:1.4rem;color:#ef4444;"></i>
                    </div>
                    <h5 class="fw-bold mb-1" style="color:#0f172a;">Delete Supplier?</h5>
                    <p class="mb-1" id="deleteSupplierName" style="color:#0f172a; font-weight:600;"></p>
                    <p class="mb-0" style="color:#94a3b8; font-size:0.85rem;">This action cannot be undone.</p>
                </div>
                <div class="d-flex gap-2 px-4 pb-4">
                    <button type="button" class="btn btn-outline-secondary rounded-pill flex-grow-1 py-2"
                            data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-danger rounded-pill flex-grow-1 py-2 fw-semibold">
                        <i class="fas fa-trash-can me-2"></i>Delete
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
<script>
    // ── Populate Edit modal ──────────────────────────────────
    document.getElementById('editSupplierModal').addEventListener('show.bs.modal', function (e) {
        const b = e.relatedTarget;
        document.getElementById('editId').value            = b.dataset.id;
        document.getElementById('editName').value          = b.dataset.name;
        document.getElementById('editServiceType').value   = b.dataset.servicetype;
        document.getElementById('editPhone').value         = b.dataset.phone;
        document.getElementById('editEmail').value         = b.dataset.email;
        document.getElementById('editLocation').value      = b.dataset.location;
        document.getElementById('editContactPerson').value = b.dataset.contactperson;
        document.getElementById('editStatus').value        = b.dataset.status;
    });

    // ── Populate Delete modal ────────────────────────────────
    document.getElementById('deleteModal').addEventListener('show.bs.modal', function (e) {
        const b = e.relatedTarget;
        document.getElementById('deleteId').value              = b.dataset.id;
        document.getElementById('deleteSupplierName').textContent = b.dataset.name;
    });

    // ── Export (basic CSV) ───────────────────────────────────
    function exportSuppliers() {
        const rows = [['Name','Service Type','Phone','Email','Location','Contact Person','Status']];
        document.querySelectorAll('.edit-btn').forEach(btn => {
            rows.push([
                btn.dataset.name, btn.dataset.servicetype, btn.dataset.phone,
                btn.dataset.email, btn.dataset.location, btn.dataset.contactperson, btn.dataset.status
            ]);
        });
        const csv  = rows.map(r => r.map(c => `"${(c||'').replace(/"/g,'""')}"`).join(',')).join('\n');
        const link = document.createElement('a');
        link.href  = 'data:text/csv;charset=utf-8,' + encodeURIComponent(csv);
        link.download = 'suppliers.csv';
        link.click();
    }
</script>
}
