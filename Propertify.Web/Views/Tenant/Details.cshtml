@model Propertify.Web.Models.Tenant
@{
    ViewData["Title"] = "Tenant Details";
}

<div class="container-fluid py-4" dir="rtl" style="max-width: 100%; padding-left: 1rem; padding-right: 1rem;">
    <!-- Header -->
    <div class="d-flex justify-content-between align-items-center mb-4 flex-wrap gap-2">
        <div>
            <h3 class="fw-bold text-primary mb-0"><i class="fas fa-user-tag ms-2"></i>Tenant Details</h3>
            <p class="text-muted small mb-0">View complete information for @Model.FullNameAr</p>
        </div>
        <div class="d-flex gap-2">
            <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-warning rounded-pill px-4 shadow-sm">
                <i class="fas fa-edit ms-1"></i> Edit
            </a>
            <a asp-action="Index" class="btn btn-outline-secondary rounded-pill px-4 shadow-sm">
                <i class="fas fa-arrow-left ms-1"></i> Back to List
            </a>
        </div>
    </div>

    <div class="row g-4">
        <!-- Main Info Card -->
        <div class="col-lg-8">
            <div class="card border-0 shadow-sm rounded-4 overflow-hidden h-100">
                <div class="card-header bg-primary text-white p-3 border-0">
                    <h5 class="mb-0 fw-bold"><i class="fas fa-info-circle ms-2"></i>Personal Information</h5>
                </div>
                <div class="card-body p-4">
                    <div class="row g-4">
                        <div class="col-md-6">
                            <label class="text-muted small d-block mb-1">Full Name (Arabic)</label>
                            <p class="fw-bold fs-5 text-dark mb-0">@Model.FullNameAr</p>
                        </div>
                        <div class="col-md-6">
                            <label class="text-muted small d-block mb-1">Full Name (English)</label>
                            <p class="fw-bold fs-5 text-dark mb-0">@Model.FullNameEn</p>
                        </div>
                        <div class="col-md-6">
                            <label class="text-muted small d-block mb-1">National ID / Passport Number</label>
                            <p class="fw-bold text-dark mb-0">@Model.IdNumber</p>
                        </div>
                        <div class="col-md-6">
                            <label class="text-muted small d-block mb-1">Phone Number</label>
                            <p class="fw-bold text-dark mb-0 ltr-text">@Model.Phone</p>
                        </div>
                        <div class="col-md-6">
                            <label class="text-muted small d-block mb-1">Email</label>
                            <p class="fw-bold text-dark mb-0">@(string.IsNullOrEmpty(Model.Email) ? "N/A" : Model.Email)</p>
                        </div>
                        <div class="col-md-6">
                            <label class="text-muted small d-block mb-1">Nationality</label>
                            <p class="fw-bold text-dark mb-0">@Model.Nationality</p>
                        </div>
                        <div class="col-12">
                            <hr class="my-2 border-light">
                        </div>
                        <div class="col-md-6">
                            <label class="text-muted small d-block mb-1">Status</label>
                            @if (Model.IsArchived)
                            {
                                <span class="badge bg-secondary-subtle text-secondary rounded-pill px-4">Archived</span>
                            }
                            else
                            {
                                <span class="badge bg-success-subtle text-success rounded-pill px-4">Active</span>
                            }
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Property Info & Document -->
        <div class="col-lg-4">
            <div class="row g-4 h-100">
                <div class="col-12">
                    <div class="card border-0 shadow-sm rounded-4 h-100">
                        <div class="card-header bg-dark text-white p-3 border-0">
                            <h5 class="mb-0 fw-bold"><i class="fas fa-building ms-2"></i>Lease Information</h5>
                        </div>
                        <div class="card-body p-4">
                            <div class="text-center mb-4">
                                <div class="bg-primary-subtle text-primary rounded-circle d-inline-flex align-items-center justify-content-center mb-2" style="width: 60px; height: 60px;">
                                    <i class="fas fa-home fa-2x"></i>
                                </div>
                                <h4 class="fw-bold text-primary mb-0">Unit @(Model.Unit?.UnitNumber ?? "N/A")</h4>
                                <p class="text-muted">@(Model.Unit?.Property?.Name ?? "Property Info Missing")</p>
                            </div>
                            
                            <div class="d-flex justify-content-between align-items-center mb-2 p-2 bg-light rounded-3">
                                <span class="small text-muted">Rent Amount</span>
                                <span class="fw-bold text-dark">@(Model.Unit?.RentAmount.ToString("N3") ?? "0.000") OMR</span>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="col-12">
                    <div class="card border-0 shadow-sm rounded-4 h-100">
                        <div class="card-header bg-info text-white p-3 border-0">
                            <h5 class="mb-0 fw-bold"><i class="fas fa-file-alt ms-2"></i>ID Document</h5>
                        </div>
                        <div class="card-body p-4 text-center">
                            @if (!string.IsNullOrEmpty(Model.IdDocumentPath))
                            {
                                <img src="@Model.IdDocumentPath" class="img-fluid rounded-3 shadow-sm mb-3 clickable-img" style="max-height: 200px;" onclick="window.open(this.src)">
                                <a href="@Model.IdDocumentPath" target="_blank" class="btn btn-sm btn-outline-info rounded-pill w-100">
                                    <i class="fas fa-external-link-alt ms-1"></i> View Full Document
                                </a>
                            }
                            else
                            {
                                <div class="py-5 text-muted opacity-50">
                                    <i class="fas fa-file-image fa-3x mb-2"></i>
                                    <p class="small mb-0">No document uploaded</p>
                                </div>
                            }
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .ltr-text { direction: ltr; display: inline-block; }
    .clickable-img { cursor: pointer; transition: transform 0.2s; }
    .clickable-img:hover { transform: scale(1.02); }
</style>
