@model IEnumerable<Propertify.Web.Models.Tenant>

@{
    ViewData["Title"] = "Tenants Management | Propertify";
    var avatarColors = new[] { "#3b82f6", "#8b5cf6", "#10b981", "#f59e0b", "#ef4444", "#ec4899" };
    var tenantAccounts = ViewBag.TenantAccounts as Dictionary<int, string> ?? new Dictionary<int, string>();
}

@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show mb-3" role="alert">
        <i class="fas fa-check-circle me-2"></i>@TempData["Success"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}
@if (TempData["Error"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show mb-3" role="alert">
        <i class="fas fa-exclamation-circle me-2"></i>@TempData["Error"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<div class="container-fluid py-4" style="max-width:100%;">

    <!-- Header -->
    <div class="d-flex justify-content-between align-items-center mb-4 flex-wrap gap-2">
        <div>
            <h4 class="fw-bold mb-0" style="color:#0f172a;">Tenants Management</h4>
            <p class="mb-0" style="color:#94a3b8; font-size:0.83rem;">
                @Model.Count() tenant records
            </p>
        </div>
        <a asp-action="Create" class="btn btn-primary rounded-pill px-4">
            <i class="fas fa-plus me-1"></i> Add New Tenant
        </a>
    </div>

    <!-- Search & Archive Filter -->
    <div class="card border-0 shadow-sm rounded-4 p-3 mb-4">
        <form asp-action="Index" method="get" class="row g-3 align-items-center">
            <div class="col-md-7">
                <div class="input-group">
                    <span class="input-group-text bg-light border-0">
                        <i class="fas fa-search text-muted"></i>
                    </span>
                    <input type="text" name="searchTerm" value="@ViewBag.SearchTerm"
                           class="form-control bg-light border-0 shadow-none"
                           placeholder="Search by name, national ID, or unit number...">
                </div>
            </div>
            <div class="col-md-3">
                <div class="form-check form-switch mt-1">
                    <input class="form-check-input" type="checkbox" name="showArchived" value="true"
                           id="archiveSwitch"
                           @(ViewBag.ShowingArchived == true ? "checked" : "")
                           onchange="this.form.submit()">
                    <label class="form-check-label fw-bold small ms-2" for="archiveSwitch">
                        Show Archived
                    </label>
                </div>
            </div>
            <div class="col-md-2">
                <button type="submit" class="btn btn-dark rounded-pill px-4 w-100">Search</button>
            </div>
        </form>
    </div>

    <!-- Tenant Cards -->
    @if (Model != null && Model.Any())
    {
        <div class="row g-4">
            @foreach (var item in Model)
            {
                var initial = item.FirstNameAr?.FirstOrDefault().ToString()?.ToUpper() ?? "?";
                var colorIdx = Math.Abs((item.FirstNameAr ?? "").GetHashCode()) % avatarColors.Length;
                var avatarBg = avatarColors[colorIdx];
                var unitRent = item.Unit?.RentAmount ?? 0m;

                <div class="col-xl-4 col-lg-6">
                    <div class="tenant-card card border-0 shadow-sm rounded-4 overflow-hidden h-100 d-flex flex-column">

                        <!-- Card Top: Avatar + Name -->
                        <div class="p-4 pb-3 d-flex gap-3 align-items-start">
                            <div class="tenant-avatar rounded-3 fw-bold text-white d-flex align-items-center justify-content-center flex-shrink-0"
                                 style="width:52px;height:52px;background:@avatarBg;font-size:1.3rem;">
                                @initial
                            </div>
                            <div class="overflow-hidden flex-grow-1">
                                <h6 class="fw-bold mb-0 text-truncate" title="@item.FullNameAr">
                                    @item.FullNameAr
                                </h6>
                                <div class="text-muted small text-truncate">@item.FullNameEn</div>
                                @if (!string.IsNullOrEmpty(item.Nationality) || item.Unit != null)
                                {
                                    <div class="d-flex align-items-center gap-2 mt-1 flex-wrap">
                                        @if (!string.IsNullOrEmpty(item.Nationality))
                                        {
                                            <span class="badge bg-light text-muted border small">
                                                <i class="fas fa-globe me-1"></i>@item.Nationality
                                            </span>
                                        }
                                        @if (item.Unit != null)
                                        {
                                            <span class="badge bg-primary-subtle text-primary border border-primary-subtle small">
                                                <i class="fas fa-door-open me-1"></i>Unit @item.Unit.UnitNumber
                                            </span>
                                            @if (item.Unit.Property != null)
                                            {
                                                <span class="badge bg-info-subtle text-info border border-info-subtle small">
                                                    <i class="fas fa-building me-1"></i>@item.Unit.Property.Name
                                                </span>
                                            }
                                        }
                                    </div>
                                }
                            </div>
                        </div>

                        <!-- Contact Info Rows -->
                        <div class="px-4 pb-3 flex-grow-1">
                            <div class="border-top pt-3">
                                <div class="d-flex align-items-center gap-2 mb-2 small text-muted">
                                    <i class="fas fa-phone text-primary" style="width:14px;"></i>
                                    <span>@item.Phone</span>
                                </div>
                                @if (!string.IsNullOrEmpty(item.Email))
                                {
                                    <div class="d-flex align-items-center gap-2 mb-2 small text-muted">
                                        <i class="fas fa-envelope text-primary" style="width:14px;"></i>
                                        <span class="text-truncate">@item.Email</span>
                                    </div>
                                }
                                @if (item.Unit != null)
                                {
                                    @if (item.Unit.Property != null)
                                    {
                                        <div class="d-flex align-items-center gap-2 mb-2 small text-muted">
                                            <i class="fas fa-building text-primary" style="width:14px;"></i>
                                            <span class="fw-semibold text-dark">@item.Unit.Property.Name</span>
                                        </div>
                                    }
                                    <div class="d-flex align-items-center gap-2 mb-2 small text-muted">
                                        <i class="fas fa-layer-group text-primary" style="width:14px;"></i>
                                        <span>Floor @item.Unit.FloorNumber &bull; Unit @item.Unit.UnitNumber</span>
                                    </div>
                                }
                                <div class="d-flex align-items-center gap-2 small text-muted">
                                    <i class="fas fa-id-card text-primary" style="width:14px;"></i>
                                    <span>ID: @item.IdNumber</span>
                                </div>
                            </div>
                        </div>

                        <!-- Card Footer: Rent + Status + Button -->
                        <div class="px-4 py-3 border-top d-flex align-items-center justify-content-between bg-light">
                            <div>
                                <div class="fw-bold text-primary small">
                                    @unitRent.ToString("N0") OMR
                                    <span class="text-muted fw-normal">/mo</span>
                                </div>
                                @if (item.IsArchived)
                                {
                                    <span class="badge bg-secondary-subtle text-secondary rounded-pill small px-2">Archived</span>
                                }
                                else
                                {
                                    <span class="badge bg-success-subtle text-success rounded-pill small px-2">Active</span>
                                }
                            </div>
                            <div class="d-flex gap-1 flex-wrap">
                                <a asp-action="Details" asp-route-id="@item.Id"
                                   class="btn btn-sm btn-dark rounded-pill px-3">
                                    <i class="fas fa-user me-1"></i> View
                                </a>
                                @if (tenantAccounts.ContainsKey(item.Id))
                                {
                                    <span class="btn btn-sm btn-success rounded-pill px-2 disabled"
                                          title="Mobile account: @tenantAccounts[item.Id]">
                                        <i class="fas fa-mobile-alt me-1"></i> App
                                    </span>
                                }
                                else if (!item.IsArchived)
                                {
                                    <button type="button"
                                            class="btn btn-sm btn-outline-primary rounded-pill px-2"
                                            title="Create mobile app account"
                                            data-bs-toggle="modal" data-bs-target="#mobileAccountModal"
                                            data-tenant-id="@item.Id"
                                            data-tenant-name="@item.FullNameEn"
                                            data-tenant-email="@item.Email">
                                        <i class="fas fa-mobile-alt me-1"></i> App
                                    </button>
                                }
                                <a asp-action="Edit" asp-route-id="@item.Id"
                                   class="btn btn-sm btn-outline-secondary rounded-circle"
                                   style="width:32px;height:32px;padding:0;display:flex;align-items:center;justify-content:center;"
                                   title="Edit">
                                    <i class="fas fa-edit" style="font-size:.75rem;"></i>
                                </a>
                                @if (!item.IsArchived)
                                {
                                    <form asp-action="Archive" asp-route-id="@item.Id" method="post" class="d-inline"
                                          onsubmit="return confirm('Archive this tenant?')">
                                        <button type="submit"
                                                class="btn btn-sm btn-outline-danger rounded-circle"
                                                style="width:32px;height:32px;padding:0;display:flex;align-items:center;justify-content:center;"
                                                title="Archive">
                                            <i class="fas fa-archive" style="font-size:.75rem;"></i>
                                        </button>
                                    </form>
                                }
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
    else
    {
        <div class="text-center py-5 text-muted">
            <i class="fas fa-user-slash fa-3x mb-3 opacity-25 d-block"></i>
            <p class="mb-1">No tenant records match the search criteria.</p>
            <small>Try adjusting your search or toggle the archive switch.</small>
        </div>
    }
</div>

<!-- Mobile Account Modal -->
<div class="modal fade" id="mobileAccountModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content rounded-4 border-0 shadow">
            <div class="modal-header border-0 pb-0">
                <h5 class="modal-title fw-bold">
                    <i class="fas fa-mobile-alt text-primary me-2"></i>Create Mobile App Account
                </h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <form asp-action="CreateMobileAccount" method="post">
                @Html.AntiForgeryToken()
                <input type="hidden" name="tenantId" id="modal-tenantId" />
                <div class="modal-body pt-2">
                    <p class="text-muted small mb-3">
                        Creating a login for: <strong id="modal-tenantName"></strong>
                    </p>
                    <div class="mb-3">
                        <label class="form-label fw-semibold small">Email <span class="text-danger">*</span></label>
                        <input type="email" name="email" id="modal-email" class="form-control rounded-3"
                               placeholder="tenant@example.com" required />
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-semibold small">Password <span class="text-danger">*</span></label>
                        <input type="password" name="password" class="form-control rounded-3"
                               placeholder="Minimum 6 characters" minlength="6" required />
                    </div>
                    <div class="mb-1">
                        <label class="form-label fw-semibold small">Permissions</label>
                        <div class="d-flex gap-3">
                            <div class="form-check">
                                <input class="form-check-input" type="checkbox" name="permissions" value="Contracts" id="perm-contracts" checked>
                                <label class="form-check-label small" for="perm-contracts">Contracts</label>
                            </div>
                            <div class="form-check">
                                <input class="form-check-input" type="checkbox" name="permissions" value="Invoices" id="perm-invoices" checked>
                                <label class="form-check-label small" for="perm-invoices">Invoices</label>
                            </div>
                            <div class="form-check">
                                <input class="form-check-input" type="checkbox" name="permissions" value="Maintenance" id="perm-maintenance" checked>
                                <label class="form-check-label small" for="perm-maintenance">Maintenance</label>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="modal-footer border-0 pt-0">
                    <button type="button" class="btn btn-light rounded-pill px-4" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-primary rounded-pill px-4">
                        <i class="fas fa-user-plus me-1"></i> Create Account
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

<style>
    .tenant-card { transition: transform .15s, box-shadow .15s; }
    .tenant-card:hover { transform: translateY(-2px); box-shadow: 0 6px 20px rgba(0,0,0,0.1) !important; }
    .form-check-input:checked { background-color: #0d6efd; border-color: #0d6efd; }
</style>

<script>
    // Populate modal with tenant data
    document.getElementById('mobileAccountModal').addEventListener('show.bs.modal', function (e) {
        var btn = e.relatedTarget;
        document.getElementById('modal-tenantId').value   = btn.dataset.tenantId;
        document.getElementById('modal-tenantName').textContent = btn.dataset.tenantName;
        document.getElementById('modal-email').value      = btn.dataset.tenantEmail || '';
    });

    // Build comma-separated permissions string before submit
    document.querySelector('#mobileAccountModal form').addEventListener('submit', function () {
        var checked = [...this.querySelectorAll('input[name="permissions"]:checked')]
            .map(cb => cb.value).join(',');
        var hidden = document.createElement('input');
        hidden.type  = 'hidden';
        hidden.name  = 'permissions';
        hidden.value = checked;
        this.appendChild(hidden);
        this.querySelectorAll('input[type=checkbox][name="permissions"]')
            .forEach(cb => cb.disabled = true);
    });
</script>
