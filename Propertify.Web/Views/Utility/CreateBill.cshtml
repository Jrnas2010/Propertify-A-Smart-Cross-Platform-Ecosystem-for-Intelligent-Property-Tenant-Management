@model Propertify.Web.Models.UtilityBill
@using System.Text.Json
@{
    ViewData["Title"] = "Create Bill | Propertify";

    var units   = ViewBag.Units   as List<Propertify.Web.Models.Unit>   ?? new();
    var tenants = ViewBag.Tenants as List<Propertify.Web.Models.Tenant> ?? new();

    // Build unit→tenant map for JS
    var unitTenantMap = tenants.ToDictionary(t => t.UnitId, t => new { t.Id, name = t.FirstNameEn + " " + t.LastNameEn });
    var mapJson = JsonSerializer.Serialize(unitTenantMap);
}

<style>
    .create-bill-wrap { max-width: 820px; margin: 0 auto; }

    .cb-card {
        background: #fff;
        border-radius: 18px;
        border: 1px solid #f1f5f9;
        box-shadow: 0 2px 12px rgba(0,0,0,0.06);
        padding: 36px 40px;
    }

    .cb-label {
        font-size: 0.72rem;
        font-weight: 700;
        letter-spacing: 0.09em;
        text-transform: uppercase;
        color: #94a3b8;
        margin-bottom: 6px;
        display: block;
    }

    .cb-input {
        width: 100%;
        background: #f8fafc;
        border: 1.5px solid #e2e8f0;
        border-radius: 10px;
        padding: 11px 14px;
        font-size: 0.88rem;
        color: #0f172a;
        outline: none;
        transition: border-color .15s;
    }
    .cb-input:focus { border-color: #6366f1; background: #fff; }
    .cb-input:disabled { opacity: .5; cursor: not-allowed; }

    select.cb-input { cursor: pointer; }

    .type-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 10px; }
    .type-opt { display: none; }
    .type-label {
        display: flex; flex-direction: column; align-items: center; justify-content: center;
        gap: 6px; padding: 14px 8px; border-radius: 12px;
        border: 2px solid #e2e8f0; background: #f8fafc;
        cursor: pointer; transition: all .15s; font-size: 0.72rem;
        font-weight: 700; letter-spacing: 0.06em; text-transform: uppercase; color: #64748b;
    }
    .type-label i { font-size: 1.2rem; }
    .type-opt:checked + .type-label {
        border-color: #6366f1; background: #eef2ff; color: #6366f1;
    }
    .type-label-rent      i { color: #f97316; }
    .type-label-elec      i { color: #eab308; }
    .type-label-water     i { color: #3b82f6; }
    .type-label-building  i { color: #64748b; }
    .type-opt:checked + .type-label-rent     { border-color:#f97316; background:#fff7ed; color:#f97316; }
    .type-opt:checked + .type-label-elec     { border-color:#eab308; background:#fefce8; color:#eab308; }
    .type-opt:checked + .type-label-water    { border-color:#3b82f6; background:#eff6ff; color:#3b82f6; }
    .type-opt:checked + .type-label-building { border-color:#64748b; background:#f8fafc; color:#64748b; }

    .reading-row { position: relative; }
    .arrow-sep {
        position: absolute; left: 50%; top: 50%; transform: translate(-50%, -50%);
        width: 28px; height: 28px; border-radius: 50%; background: #f1f5f9;
        display: flex; align-items: center; justify-content: center; color: #94a3b8; font-size: 0.75rem;
    }

    .amount-display {
        background: linear-gradient(135deg, #eef2ff 0%, #e0e7ff 100%);
        border: 1.5px solid #c7d2fe;
        border-radius: 12px;
        padding: 14px 18px;
        display: flex; align-items: center; justify-content: space-between;
    }
    .amount-value { font-size: 1.5rem; font-weight: 800; color: #4f46e5; }
    .amount-sub   { font-size: 0.7rem; font-weight: 700; letter-spacing: 0.07em; color: #818cf8; text-transform: uppercase; }

    .cb-submit {
        background: #0f172a; color: #fff; border: none; border-radius: 12px;
        padding: 13px 36px; font-size: 0.85rem; font-weight: 700;
        letter-spacing: 0.07em; cursor: pointer; transition: background .15s;
    }
    .cb-submit:hover { background: #1e293b; }

    .cb-cancel {
        color: #64748b; text-decoration: none; font-size: 0.85rem;
        font-weight: 600; padding: 13px 20px; border-radius: 12px;
        transition: background .1s;
    }
    .cb-cancel:hover { background: #f8fafc; color: #0f172a; }

    .tenant-badge {
        display: flex; align-items: center; gap-10px; gap: 10px;
        background: #f0fdf4; border: 1.5px solid #bbf7d0;
        border-radius: 10px; padding: 10px 14px;
        font-size: 0.83rem; font-weight: 600; color: #16a34a;
    }

    .section-divider {
        border: none; border-top: 1px solid #f1f5f9; margin: 28px 0;
    }
</style>

<div class="py-4 px-1">
    <div class="create-bill-wrap">

        <!-- Header -->
        <div class="d-flex align-items-center gap-3 mb-4">
            <a asp-action="BillingList" class="d-flex align-items-center justify-content-center"
               style="width:38px;height:38px;border-radius:10px;background:#f8fafc;border:1px solid #e2e8f0;color:#64748b;text-decoration:none;">
                <i class="fas fa-arrow-left" style="font-size:0.85rem;"></i>
            </a>
            <div>
                <h2 class="fw-bold mb-0" style="color:#0f172a;font-size:1.7rem;">New Bill</h2>
                <p class="mb-0" style="font-size:0.72rem;letter-spacing:0.1em;color:#94a3b8;text-transform:uppercase;margin-top:2px;">
                    CREATE UTILITY INVOICE
                </p>
            </div>
        </div>

        <div class="cb-card">
            <form asp-action="CreateBill" method="post" id="createBillForm">
                @Html.AntiForgeryToken()

                <!-- ── Bill Type ───────────────────────────────────── -->
                <div class="mb-4">
                    <label class="cb-label">Bill Type</label>
                    <div class="type-grid">
                        @foreach (var (val, icon, cls, lbl) in new[]{
                            ("Rent",        "fas fa-home",     "type-label-rent",     "Rent"),
                            ("Electricity", "fas fa-bolt",     "type-label-elec",     "Electricity"),
                            ("Water",       "fas fa-tint",     "type-label-water",    "Water"),
                            ("Building",    "fas fa-building", "type-label-building", "Building")
                        })
                        {
                            <div>
                                <input type="radio" name="ServiceType" id="type_@val" value="@val"
                                       class="type-opt" @(val == "Electricity" ? "checked" : "")>
                                <label for="type_@val" class="type-label @cls">
                                    <i class="@icon"></i>@lbl
                                </label>
                            </div>
                        }
                    </div>
                    <span asp-validation-for="ServiceType" class="text-danger" style="font-size:0.78rem;"></span>
                </div>

                <hr class="section-divider">

                <!-- ── Unit & Tenant ──────────────────────────────── -->
                <div class="row g-3 mb-4">
                    <div class="col-md-6">
                        <label class="cb-label" for="unitSelect">Unit</label>
                        <select id="unitSelect" name="UnitId" class="cb-input" required>
                            <option value="">— Select Unit —</option>
                            @foreach (var grp in units.GroupBy(u => u.Property?.Name ?? "Unknown"))
                            {
                                <optgroup label="@grp.Key">
                                    @foreach (var u in grp)
                                    {
                                        <option value="@u.Id"
                                                data-tenant-id="@(tenants.FirstOrDefault(t => t.UnitId == u.Id)?.Id ?? 0)"
                                                data-tenant-name="@(tenants.FirstOrDefault(t => t.UnitId == u.Id)?.FirstNameEn + " " + tenants.FirstOrDefault(t => t.UnitId == u.Id)?.LastNameEn)">
                                            Unit @u.UnitNumber — Floor @u.FloorNumber
                                        </option>
                                    }
                                </optgroup>
                            }
                        </select>
                    </div>
                    <div class="col-md-6">
                        <label class="cb-label" for="tenantSelect">Tenant</label>
                        <select id="tenantSelect" name="TenantId" class="cb-input">
                            <option value="0">— Auto from Unit —</option>
                            @foreach (var t in tenants)
                            {
                                <option value="@t.Id">@t.FirstNameEn @t.LastNameEn</option>
                            }
                        </select>
                    </div>
                </div>

                <!-- Tenant badge (auto-filled hint) -->
                <div id="tenantBadge" class="tenant-badge mb-4" style="display:none;">
                    <i class="fas fa-user-check"></i>
                    <span id="tenantBadgeText"></span>
                </div>

                <hr class="section-divider">

                <!-- ── Readings ───────────────────────────────────── -->
                <div class="mb-1">
                    <label class="cb-label">Meter Readings</label>
                </div>
                <div class="row g-3 reading-row mb-1 align-items-end">
                    <div class="col-5">
                        <label class="cb-label" for="prevReading">Previous Reading</label>
                        <input type="number" id="prevReading" name="PreviousReading" class="cb-input"
                               min="0" step="0.01" value="0" oninput="calcAmount()">
                    </div>
                    <div class="col-2 text-center pb-1">
                        <div class="arrow-sep"><i class="fas fa-arrow-right"></i></div>
                    </div>
                    <div class="col-5">
                        <label class="cb-label" for="currReading">Current Reading</label>
                        <input type="number" id="currReading" name="CurrentReading" class="cb-input"
                               min="0" step="0.01" value="0" oninput="calcAmount()">
                    </div>
                </div>
                <p class="text-muted mb-4" style="font-size:0.75rem;">
                    <i class="fas fa-info-circle me-1"></i>
                    Units consumed: <strong id="unitsConsumed">0</strong>
                </p>

                <!-- ── Total Amount ───────────────────────────────── -->
                <div class="mb-4">
                    <label class="cb-label">Total Amount (ر.ع)</label>
                    <div class="amount-display mb-2">
                        <div>
                            <div class="amount-sub">Calculated Amount</div>
                            <div class="amount-value" id="calcAmountDisplay">0.000</div>
                        </div>
                        <i class="fas fa-calculator" style="color:#c7d2fe;font-size:1.4rem;"></i>
                    </div>
                    <input type="number" id="totalAmount" name="TotalAmount" class="cb-input"
                           min="0" step="0.001" placeholder="Override amount (optional)" value="">
                    <p class="text-muted mt-1" style="font-size:0.73rem;">
                        Leave blank to use the calculated amount above.
                    </p>
                </div>

                <hr class="section-divider">

                <!-- ── Date & Status ─────────────────────────────── -->
                <div class="row g-3 mb-4">
                    <div class="col-md-6">
                        <label class="cb-label" for="issueDate">Issue Date</label>
                        <input type="date" id="issueDate" name="IssueDate" class="cb-input"
                               value="@DateTime.Today.ToString("yyyy-MM-dd")">
                    </div>
                    <div class="col-md-6">
                        <label class="cb-label" for="statusSelect">Status</label>
                        <select id="statusSelect" name="Status" class="cb-input">
                            <option value="Unpaid">Unpaid</option>
                            <option value="Paid">Paid</option>
                            <option value="Overdue">Overdue</option>
                        </select>
                    </div>
                </div>

                <!-- ── Actions ───────────────────────────────────── -->
                <div class="d-flex align-items-center gap-3 pt-2">
                    <button type="submit" class="cb-submit">
                        <i class="fas fa-plus me-2"></i>CREATE BILL
                    </button>
                    <a asp-action="BillingList" class="cb-cancel">Cancel</a>
                </div>

            </form>
        </div>
    </div>
</div>

<script>
    // Unit → tenant map injected from server
    const unitTenantMap = @Html.Raw(mapJson);

    const unitSel    = document.getElementById('unitSelect');
    const tenantSel  = document.getElementById('tenantSelect');
    const badge      = document.getElementById('tenantBadge');
    const badgeText  = document.getElementById('tenantBadgeText');

    unitSel.addEventListener('change', function () {
        const opt = this.options[this.selectedIndex];
        const tid  = opt.dataset.tenantId  ? parseInt(opt.dataset.tenantId)  : 0;
        const name = opt.dataset.tenantName ? opt.dataset.tenantName.trim() : '';

        if (tid && tid > 0) {
            // Pre-select the matched tenant
            tenantSel.value = tid;
            badge.style.display = 'flex';
            badgeText.textContent = 'Tenant auto-filled: ' + name;
        } else {
            tenantSel.value = 0;
            badge.style.display = 'none';
        }
    });

    // Re-hide badge if user manually changes tenant
    tenantSel.addEventListener('change', function () {
        badge.style.display = 'none';
    });

    // Auto-calculate amount from readings
    const TARIFF = 0.020; // fallback tariff per unit consumed

    function calcAmount() {
        const prev = parseFloat(document.getElementById('prevReading').value) || 0;
        const curr = parseFloat(document.getElementById('currReading').value) || 0;
        const consumed = Math.max(0, curr - prev);
        document.getElementById('unitsConsumed').textContent = consumed.toFixed(2);
        const amount = consumed * TARIFF;
        document.getElementById('calcAmountDisplay').textContent = amount.toFixed(3);
    }

    // On submit: if override amount empty, push calculated value into hidden field
    document.getElementById('createBillForm').addEventListener('submit', function () {
        const override = document.getElementById('totalAmount').value.trim();
        if (!override) {
            const prev = parseFloat(document.getElementById('prevReading').value) || 0;
            const curr = parseFloat(document.getElementById('currReading').value) || 0;
            const consumed = Math.max(0, curr - prev);
            document.getElementById('totalAmount').value = (consumed * TARIFF).toFixed(3);
        }
    });
</script>
